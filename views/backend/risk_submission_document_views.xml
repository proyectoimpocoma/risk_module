<odoo>
    <record id="view_risk_additional_document_wizard_form" model="ir.ui.view">
        <field name="name">risk.additional.document.wizard.form</field>
        <field name="model">risk.additional.document.wizard</field>
        <field name="arch" type="xml">
            <form string="Solicitar documentos adicionales">
                <sheet class="risk-additional-document-wizard">
                    <div class="risk-template-wizard-intro">
                        <h2>Solicitar documentos adicionales</h2>
                        <p>Selecciona uno o varios documentos del catalogo. Solo aparecen documentos que aun no han sido solicitados en esta solicitud.</p>
                    </div>
                    <field name="submission_id" invisible="1"/>
                    <field name="available_requirement_ids" invisible="1"/>
                    <field name="no_available_documents" invisible="1"/>
                    <div class="alert alert-info" role="status" invisible="not no_available_documents">
                        Ya solicitaste todos los documentos disponibles del catalogo para esta solicitud.
                    </div>
                    <group invisible="no_available_documents">
                        <field name="requirement_ids"
                               widget="many2many_tags"
                               options="{'no_create': True, 'no_open': True}"
                               placeholder="Selecciona los documentos adicionales"/>
                        <field name="notify_third_party"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_request_document" type="object" string="Solicitar documentos" class="btn-primary"
                            invisible="no_available_documents"/>
                    <button string="Cancelar" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="view_risk_module_document_list" model="ir.ui.view">
        <field name="name">risk.module.document.list</field>
        <field name="model">risk.module.document</field>
        <field name="arch" type="xml">
            <list string="Documentos"
                  decoration-success="state == 'approved'"
                  decoration-danger="state == 'rejected'"
                  decoration-info="state == 'received'"
                  decoration-warning="state == 'pending'">
                <field name="sequence" widget="handle"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'approved'"
                       decoration-danger="state == 'rejected'"
                       decoration-info="state == 'received'"
                       decoration-warning="state == 'pending'"/>
                <field name="name" string="Documento"/>
                <field name="party" string="Persona / Vehiculo"/>
                <field name="source" string="Origen"/>
                <field name="required" string="Obligatorio"/>
                <field name="filename" string="Archivo"/>
                <field name="uploaded_at" string="Cargado"/>
                <field name="issue_date" string="Expedicion"/>
                <field name="expiration_date" string="Vencimiento"/>
                <field name="expiration_state" widget="badge" string="Vigencia"
                       decoration-success="expiration_state == 'valid'"
                       decoration-warning="expiration_state == 'expiring'"
                       decoration-danger="expiration_state == 'expired'"
                       decoration-muted="expiration_state == 'no_date'"/>
                <field name="rejection_reason" string="Motivo"/>
                <field name="observations" string="Observaciones"/>
                <field name="has_file" column_invisible="1"/>
                <field name="sharepoint_state" widget="badge" string="SharePoint"
                       decoration-success="sharepoint_state == 'synced'"
                       decoration-warning="sharepoint_state == 'pending'"
                       decoration-danger="sharepoint_state == 'error'"
                       decoration-muted="sharepoint_state == 'disabled'"/>
                <field name="sharepoint_synced_at" string="Sincronizado" optional="hide"/>
                <field name="replacement_count" string="Reenvios" optional="show"/>
                <button name="action_open_document_preview" type="object" string="Ver PDF"
                        invisible="not has_file"/>
                <button name="action_mark_received" type="object" string="Recibido"
                        invisible="state != 'pending'"/>
                <button name="action_approve" type="object" string="Aprobar"
                        invisible="state not in ('received', 'rejected')"/>
                <button name="action_reject" type="object" string="Rechazar"
                        invisible="state not in ('received', 'approved')"/>
            </list>
        </field>
    </record>

    <record id="view_risk_module_document_form" model="ir.ui.view">
        <field name="name">risk.module.document.form</field>
        <field name="model">risk.module.document</field>
        <field name="arch" type="xml">
            <form string="Documento">
                <header>
                    <button name="action_open_file" type="object" string="Abrir archivo"
                            class="btn-secondary" invisible="not has_file"/>
                    <button name="action_mark_received" type="object" string="Marcar recibido"
                            invisible="state != 'pending'"/>
                    <button name="action_approve" type="object" string="Aprobar" class="btn-primary"
                            invisible="state not in ('received', 'rejected')"/>
                    <button name="action_reject" type="object" string="Rechazar"
                            invisible="state not in ('received', 'approved')"/>
                    <button name="action_retry_sharepoint" type="object" string="Reintentar SharePoint"
                            invisible="sharepoint_state != 'error'"/>
                    <field name="state" widget="statusbar" statusbar_visible="pending,received,approved,rejected"/>
                </header>
                <sheet>
                    <div class="risk-document-preview-layout">
                        <div class="risk-document-preview">
                            <field name="has_file" invisible="1"/>
                            <field name="file" filename="filename" widget="pdf_viewer" nolabel="1"
                                   invisible="not file"/>
                            <div invisible="file or not has_file" class="alert alert-success mb-0" role="status">
                                El archivo esta almacenado en SharePoint. Usa el boton
                                "Abrir archivo" para verlo.
                            </div>
                            <div invisible="has_file" class="alert alert-info mb-0" role="status">
                                Este documento aun no tiene archivo cargado.
                            </div>
                        </div>
                        <div class="risk-document-details">
                            <group>
                                <field name="submission_id"/>
                                <field name="name"/>
                                <field name="document_type"/>
                                <field name="party"/>
                                <field name="source"/>
                                <field name="instructions" placeholder="Instrucciones para el tercero"/>
                                <field name="required"/>
                                <field name="requires_color"/>
                                <field name="requires_both_sides"/>
                                <field name="validity_required"/>
                                <field name="issue_date_required"/>
                                <field name="reject_expired"/>
                                <field name="max_age_days"/>
                                <field name="max_file_size_mb"/>
                                <field name="allowed_file_extensions"/>
                                <field name="issue_date"/>
                                <field name="expiration_date"/>
                                <field name="expiration_state" readonly="1"/>
                                <field name="filename"/>
                            </group>
                            <group string="Observaciones">
                                <field name="rejection_reason"/>
                                <field name="observations" nolabel="1"/>
                            </group>
                            <group string="Historial">
                                <field name="uploaded_by_id"/>
                                <field name="uploaded_at"/>
                                <field name="approved_by_id"/>
                                <field name="approved_at"/>
                                <field name="rejected_by_id"/>
                                <field name="rejected_at"/>
                                <field name="rejection_message_sent_at"/>
                                <field name="replacement_count"/>
                            </group>
                            <group string="SharePoint">
                                <field name="sharepoint_state"/>
                                <field name="sharepoint_web_url" widget="url" readonly="1"
                                       invisible="not sharepoint_web_url"/>
                                <field name="sharepoint_synced_at"/>
                                <field name="sharepoint_attempts"/>
                                <field name="sharepoint_error" invisible="not sharepoint_error"/>
                            </group>
                            <notebook>
                                <page string="Historial de cargas" name="versions">
                                    <field name="version_ids" nolabel="1" readonly="1">
                                        <list string="Historial de cargas"
                                              decoration-success="result == 'uploaded'"
                                              decoration-danger="result == 'failed'"
                                              decoration-muted="result == 'pending'">
                                            <field name="uploaded_at"/>
                                            <field name="version_number"/>
                                            <field name="filename"/>
                                            <field name="result" widget="badge"
                                                   decoration-success="result == 'uploaded'"
                                                   decoration-danger="result == 'failed'"
                                                   decoration-muted="result == 'pending'"/>
                                            <field name="is_replacement"/>
                                            <field name="triggered_by_rejection" optional="show"/>
                                            <field name="uploaded_by_id"/>
                                            <field name="error_message" optional="hide"/>
                                        </list>
                                    </field>
                                </page>
                            </notebook>
                        </div>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_risk_module_document_search" model="ir.ui.view">
        <field name="name">risk.module.document.search</field>
        <field name="model">risk.module.document</field>
        <field name="arch" type="xml">
            <search string="Documentos">
                <field name="name"/>
                <field name="submission_id"/>
                <field name="party"/>
                <filter string="Pendientes" name="pending" domain="[('state', '=', 'pending')]"/>
                <filter string="Recibidos" name="received" domain="[('state', '=', 'received')]"/>
                <filter string="Aprobados" name="approved" domain="[('state', '=', 'approved')]"/>
                <filter string="Rechazados" name="rejected" domain="[('state', '=', 'rejected')]"/>
                <filter string="Solicitud" name="group_submission" context="{'group_by': 'submission_id'}"/>
                <filter string="Relacionado con" name="group_party" context="{'group_by': 'party'}"/>
                <filter string="Estado" name="group_state" context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>

    <record id="action_risk_module_document_form_modal" model="ir.actions.act_window">
        <field name="name">Ver documento</field>
        <field name="res_model">risk.module.document</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_risk_module_document_form"/>
        <field name="target">new</field>
    </record>

    <record id="action_risk_module_document" model="ir.actions.act_window">
        <field name="name">Documentos</field>
        <field name="res_model">risk.module.document</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_group_party': 1}</field>
    </record>

    <!-- Historial de cargas (Nivel B): traza de subidas y fallos. -->
    <record id="view_risk_module_document_version_list" model="ir.ui.view">
        <field name="name">risk.module.document.version.list</field>
        <field name="model">risk.module.document.version</field>
        <field name="arch" type="xml">
            <list string="Historial de cargas"
                  create="false" edit="false"
                  decoration-success="result == 'uploaded'"
                  decoration-danger="result == 'failed'"
                  decoration-muted="result == 'pending'">
                <field name="uploaded_at"/>
                <field name="submission_id"/>
                <field name="document_name"/>
                <field name="filename"/>
                <field name="version_number"/>
                <field name="result" widget="badge"
                       decoration-success="result == 'uploaded'"
                       decoration-danger="result == 'failed'"
                       decoration-muted="result == 'pending'"/>
                <field name="is_replacement"/>
                <field name="triggered_by_rejection" optional="show"/>
                <field name="uploaded_by_id"/>
                <field name="error_message" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_risk_module_document_version_search" model="ir.ui.view">
        <field name="name">risk.module.document.version.search</field>
        <field name="model">risk.module.document.version</field>
        <field name="arch" type="xml">
            <search string="Historial de cargas">
                <field name="submission_id"/>
                <field name="document_name"/>
                <field name="filename"/>
                <filter string="Subidos" name="uploaded" domain="[('result', '=', 'uploaded')]"/>
                <filter string="Fallidos" name="failed" domain="[('result', '=', 'failed')]"/>
                <filter string="En proceso" name="pending" domain="[('result', '=', 'pending')]"/>
                <filter string="Reemplazos" name="replacements" domain="[('is_replacement', '=', True)]"/>
                <separator/>
                <filter string="Solicitud" name="group_submission" context="{'group_by': 'submission_id'}"/>
                <filter string="Resultado" name="group_result" context="{'group_by': 'result'}"/>
            </search>
        </field>
    </record>

    <record id="action_risk_module_document_version" model="ir.actions.act_window">
        <field name="name">Historial de cargas</field>
        <field name="res_model">risk.module.document.version</field>
        <field name="view_mode">list</field>
        <field name="context">{'search_default_group_result': 1}</field>
    </record>
</odoo>
