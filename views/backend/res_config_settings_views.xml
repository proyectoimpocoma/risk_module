<odoo>
    <record id="res_config_settings_view_form_risk" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.risk</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Riesgo" string="Riesgo" name="risk_module"
                     groups="base.group_system">
                    <block title="Almacenamiento en SharePoint"
                           name="risk_sharepoint_settings"
                           groups="base.group_system">
                        <setting id="risk_sp_enabled_setting"
                                 string="Guardar documentos en SharePoint"
                                 help="Sincroniza los documentos cargados por el tercero a SharePoint. Si se desactiva, los archivos quedan solo en Odoo.">
                            <field name="risk_sp_enabled"/>
                        </setting>
                        <setting string="Estado de configuracion"
                                 help="Resumen local de los datos configurados. Usa las pruebas para validar permisos reales en Microsoft Graph."
                                 invisible="not risk_sp_enabled">
                            <div class="content-group risk-sp-status-panel">
                                <field name="risk_sp_config_status" widget="badge"
                                       readonly="1" nolabel="1"
                                       decoration-success="risk_sp_config_status == 'ready'"
                                       decoration-warning="risk_sp_config_status == 'incomplete'"
                                       decoration-muted="risk_sp_config_status == 'disabled'"/>
                                <field name="risk_sp_config_summary" readonly="1"
                                       nolabel="1" class="risk-sp-status-copy"/>
                                <field name="risk_sp_location_summary" readonly="1"
                                       nolabel="1" class="risk-sp-location-copy"/>
                                <div class="risk-sp-action-row mt12">
                                    <button name="action_risk_sp_test_connection" type="object"
                                            string="Probar conexion" class="btn-primary"
                                            icon="fa-plug"/>
                                    <button name="action_risk_sp_test_root_folder" type="object"
                                            string="Probar carpeta" class="btn-secondary"
                                            icon="fa-folder-open"/>
                                </div>
                            </div>
                        </setting>
                        <setting string="Conexion (Microsoft Graph)"
                                 help="Credenciales de la app registrada en Azure AD con permiso Sites.Selected sobre el sitio de riesgos."
                                 invisible="not risk_sp_enabled">
                            <div class="content-group risk-sp-field-panel">
                                <div class="row mt16">
                                    <label for="risk_sp_tenant_id" class="col-lg-4 o_light_label"/>
                                    <field name="risk_sp_tenant_id" placeholder="Tenant ID"/>
                                </div>
                                <div class="row">
                                    <label for="risk_sp_client_id" class="col-lg-4 o_light_label"/>
                                    <field name="risk_sp_client_id" placeholder="Application / Client ID"/>
                                </div>
                                <div class="row">
                                    <label for="risk_sp_client_secret" class="col-lg-4 o_light_label"/>
                                    <field name="risk_sp_client_secret" password="True"
                                           placeholder="Client secret"/>
                                </div>
                            </div>
                        </setting>
                        <setting string="Ubicacion"
                                 help="Sitio, biblioteca y carpeta raiz donde se almacenan los documentos."
                                 invisible="not risk_sp_enabled">
                            <div class="content-group risk-sp-field-panel">
                                <div class="row mt16">
                                    <label for="risk_sp_site" class="col-lg-4 o_light_label"/>
                                    <field name="risk_sp_site" placeholder="contoso.sharepoint.com:/sites/Riesgos"/>
                                </div>
                                <div class="row">
                                    <label for="risk_sp_drive" class="col-lg-4 o_light_label"/>
                                    <field name="risk_sp_drive" placeholder="Documentos"/>
                                    <button name="action_risk_sp_select_drive" type="object"
                                            string="Elegir carpeta" class="btn-secondary btn-sm ms-2 risk-sp-inline-button"
                                            icon="fa-folder-open"
                                            title="Listar y seleccionar la biblioteca desde SharePoint"/>
                                </div>
                                <div class="row">
                                    <label for="risk_sp_root_folder" class="col-lg-4 o_light_label"/>
                                    <field name="risk_sp_root_folder" placeholder="Solicitudes"/>
                                </div>
                                <div class="risk-sp-advanced mt16">
                                    <field name="risk_sp_show_advanced" class="oe_inline"/>
                                    <label for="risk_sp_show_advanced"/>
                                    <div invisible="not risk_sp_show_advanced">
                                        <div class="risk-sp-advanced-body mt12">
                                            <div class="row">
                                                <label for="risk_sp_drive_id" class="col-lg-4 o_light_label"/>
                                                <field name="risk_sp_drive_id" placeholder="b!..." readonly="1"/>
                                            </div>
                                            <div class="row">
                                                <label for="risk_sp_root_item_id" class="col-lg-4 o_light_label"/>
                                                <field name="risk_sp_root_item_id" placeholder="01..." readonly="1"/>
                                            </div>
                                            <div class="row mt12">
                                                <label for="risk_sp_graph_children_url" class="col-lg-4 o_light_label"/>
                                                <field name="risk_sp_graph_children_url"
                                                       placeholder="https://graph.microsoft.com/v1.0/drives/.../items/.../children"/>
                                            </div>
                                            <div class="risk-sp-action-row mt8">
                                                <button name="action_risk_sp_apply_graph_url" type="object"
                                                        string="Aplicar URL Graph" class="btn-secondary"
                                                        icon="fa-link"/>
                                                <button name="action_risk_sp_explore_graph_url" type="object"
                                                        string="Explorar URL" class="btn-secondary"
                                                        icon="fa-search"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </setting>
                        <setting string="Comportamiento"
                                 help="Politica de copia local y reintentos de sincronizacion."
                                 invisible="not risk_sp_enabled">
                            <div class="content-group risk-sp-field-panel">
                                <div class="mt16">
                                    <field name="risk_sp_purge_local" class="oe_inline"/>
                                    <label for="risk_sp_purge_local"/>
                                </div>
                                <div class="row mt16">
                                    <label for="risk_sp_max_attempts" class="col-lg-4 o_light_label"/>
                                    <field name="risk_sp_max_attempts"/>
                                </div>
                            </div>
                        </setting>
                        <setting string="Mantenimiento"
                                 help="Operaciones manuales para documentos ya cargados antes de activar SharePoint."
                                 invisible="not risk_sp_enabled">
                            <div class="mt8 risk-sp-maintenance">
                                <button name="action_risk_sp_backfill" type="object"
                                        string="Sincronizar documentos existentes"
                                        class="btn-secondary"
                                        icon="fa-refresh"
                                        confirm="Esto marcara los documentos existentes para sincronizarlos en el cron de SharePoint. ¿Continuar?"/>
                                <button type="action" name="%(action_risk_sharepoint_route)d"
                                        string="Configurar rutas por tipo"
                                        class="btn-link risk-sp-route-link"
                                        icon="fa-sitemap"/>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

    <record id="action_risk_sharepoint_settings" model="ir.actions.act_window">
        <field name="name">Ajustes de SharePoint</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
        <field name="context">{'module': 'risk_module'}</field>
    </record>

    <menuitem id="menu_risk_sharepoint_settings"
              name="Ajustes de SharePoint"
              parent="menu_risk_module_configuration"
              action="action_risk_sharepoint_settings"
              sequence="90"
              groups="base.group_system"/>
</odoo>
