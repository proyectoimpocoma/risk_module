<odoo>
    <record id="view_risk_document_reject_wizard_form" model="ir.ui.view">
        <field name="name">risk.module.document.reject.wizard.form</field>
        <field name="model">risk.module.document.reject.wizard</field>
        <field name="arch" type="xml">
            <form string="Rechazar documento">
                <group>
                    <field name="document_id"/>
                    <field name="message_template_id"
                           options="{'no_create': True, 'no_open': True}"/>
                    <field name="rejection_reason" invisible="1"/>
                    <field name="observations"
                           placeholder="Este mensaje se enviara al usuario para que corrija el documento."/>
                </group>
                <footer>
                    <button name="action_confirm" type="object" string="Rechazar documento" class="btn-primary"/>
                    <button string="Cancelar" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
