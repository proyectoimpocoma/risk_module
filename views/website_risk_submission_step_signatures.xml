<odoo>
    <template id="register_driver_step_signatures" name="Registro Vehiculo Paso Firmas">
        <div t-if="data.get('signature_error')" class="risk-error" t-esc="data.get('signature_error')"/>
        <div t-if="data.get('signature_info')" class="risk-info" t-esc="data.get('signature_info')"/>
        <!-- Sección 1: Firma y Verificación del Propietario (Paso 5) -->
        <div t-if="step == 5" class="risk-signature-card">
            <h3>Propietario / Tenedor / Representante Legal</h3>
            <div class="risk-field risk-field-full risk-switch-card">
                <div>
                    <span class="risk-switch-title">Firma unica propietario/conductor</span>
                    <span class="risk-switch-help">Usa esta opcion solo si propietario/tenedor y conductor son la misma persona.</span>
                </div>
                <label class="risk-switch" for="single_owner_driver_signature_toggle">
                    <span>No</span>
                    <input id="single_owner_driver_signature_toggle" type="checkbox" t-att-checked="'checked' if data.get('single_owner_driver_signature') == 'yes' else None"/>
                    <span class="risk-switch-track" aria-hidden="true"></span>
                    <span>Si</span>
                </label>
                <input id="single_owner_driver_signature" name="single_owner_driver_signature" type="hidden" t-att-value="data.get('single_owner_driver_signature') or 'no'"/>
            </div>
            <div t-attf-class="risk-single-signature-note #{'' if data.get('single_owner_driver_signature') == 'yes' else 'is-disabled'}" data-single-signature-note="1">
                Declaro que actuo como propietario/tenedor y conductor, y autorizo que esta firma aplique para ambas responsabilidades dentro de esta solicitud.
            </div>
            
            <!-- Subsección 1.1: Verificación de Correo (Propietario) -->
            <div class="risk-verification-box">
                <div>
                    <strong>Verificacion de correo</strong>
                    <p>
                        Correo:
                        <span t-esc="data.get('owner_email') or 'No registrado'"/>
                    </p>
                    <p t-if="data.get('owner_signature_verification_state') == 'verified' and data.get('owner_signature_email') == data.get('owner_email')" class="risk-verification-ok">
                        Correo verificado.
                    </p>
                    <p t-else="" class="risk-verification-pending">
                        Debes verificar el correo del propietario antes de continuar.
                    </p>
                </div>
                <button type="submit"
                        class="btn btn-secondary"
                        formmethod="post"
                        formaction="/registro-conductor/firma/owner/enviar-codigo">
                    Enviar codigo
                </button>
                <div class="risk-verification-code">
                    <label for="owner_signature_verification_code">Codigo recibido</label>
                    <input id="owner_signature_verification_code"
                           name="owner_signature_verification_code"
                           type="text"
                           inputmode="numeric"
                           pattern="[0-9]{6}"
                           maxlength="6"
                           autocomplete="one-time-code"/>
                    <button type="submit"
                            class="btn btn-primary"
                            formmethod="post"
                            formaction="/registro-conductor/firma/owner/verificar-codigo">
                        Verificar
                    </button>
                </div>
            </div>
            
            <!-- Subsección 1.2: Estudio Vigente y Firma (Propietario) -->
            <p>Si el propietario cuenta con estudio vigente, no debe diligenciar el siguiente espacio.</p>
            <div class="risk-choice-row">
                <span>Cuenta con estudio vigente?</span>
                <label class="risk-choice">
                    <span>SI</span>
                    <input type="radio" name="owner_has_valid_study" value="yes" t-att-checked="'checked' if data.get('owner_has_valid_study') == 'yes' else None"/>
                </label>
                <label class="risk-choice">
                    <span>NO</span>
                    <input type="radio" name="owner_has_valid_study" value="no" t-att-checked="'checked' if data.get('owner_has_valid_study') != 'yes' else None"/>
                </label>
            </div>
            <div class="risk-signature-pad" data-signature-pad="owner">
                <canvas id="owner-signature-canvas" width="720" height="190"></canvas>
                <input id="owner-signature-input" type="hidden" name="owner_signature" t-att-value="'data:image/png;base64,%s' % data.get('owner_signature') if data.get('owner_signature') else ''"/>
                <button type="button" class="btn btn-secondary risk-clear-signature" data-clear-signature="owner">Limpiar firma</button>
            </div>
            <div class="risk-field risk-field-full">
                <label for="owner_signature_document_display">Firma y número de cédula</label>
                <input id="owner_signature_document_display" type="text"
                       t-att-value="('%s - %s' % (data.get('owner_name') or '', data.get('owner_document_number') or '')) if data.get('owner_document_number') else (data.get('owner_signature_document') or '')"
                       readonly="readonly"
                       placeholder="Aquí se mostrará el nombre y cédula del propietario"/>
                <input type="hidden" name="owner_signature_document"
                       t-att-value="data.get('owner_signature_document') or data.get('owner_document_number')"/>
            </div>
        </div>

        <!-- Sección 2: Firma y Verificación del Conductor (Paso 6) -->
        <div t-if="step == 6" class="risk-signature-card">
            <h3>Conductor</h3>
            <div class="risk-verification-box">
                <div>
                    <strong>Verificacion de correo</strong>
                    <p>
                        Correo:
                        <span t-esc="data.get('driver_email') or 'No registrado'"/>
                    </p>
                    <p t-if="data.get('driver_signature_verification_state') == 'verified' and data.get('driver_signature_email') == data.get('driver_email')" class="risk-verification-ok">
                        Correo verificado.
                    </p>
                    <p t-else="" class="risk-verification-pending">
                        Debes verificar el correo del conductor antes de continuar.
                    </p>
                </div>
                <button type="submit"
                        class="btn btn-secondary"
                        formmethod="post"
                        formaction="/registro-conductor/firma/driver/enviar-codigo">
                    Enviar codigo
                </button>
                <div class="risk-verification-code">
                    <label for="driver_signature_verification_code">Codigo recibido</label>
                    <input id="driver_signature_verification_code"
                           name="driver_signature_verification_code"
                           type="text"
                           inputmode="numeric"
                           pattern="[0-9]{6}"
                           maxlength="6"
                           autocomplete="one-time-code"/>
                    <button type="submit"
                            class="btn btn-primary"
                            formmethod="post"
                            formaction="/registro-conductor/firma/driver/verificar-codigo">
                        Verificar
                    </button>
                </div>
            </div>
            
            <!-- Subsección 2.2: Estudio Vigente y Firma (Conductor) -->
            <p>Si el conductor cuenta con estudio vigente, no debe diligenciar el siguiente espacio.</p>
            <div class="risk-choice-row">
                <span>Cuenta con estudio vigente?</span>
                <label class="risk-choice">
                    <span>SI</span>
                    <input type="radio" name="driver_has_valid_study" value="yes" t-att-checked="'checked' if data.get('driver_has_valid_study') == 'yes' else None"/>
                </label>
                <label class="risk-choice">
                    <span>NO</span>
                    <input type="radio" name="driver_has_valid_study" value="no" t-att-checked="'checked' if data.get('driver_has_valid_study') != 'yes' else None"/>
                </label>
            </div>
            <div class="risk-signature-pad" data-signature-pad="driver">
                <canvas id="driver-signature-canvas" width="720" height="190"></canvas>
                <input id="driver-signature-input" type="hidden" name="driver_signature" t-att-value="'data:image/png;base64,%s' % data.get('driver_signature') if data.get('driver_signature') else ''"/>
                <button type="button" class="btn btn-secondary risk-clear-signature" data-clear-signature="driver">Limpiar firma</button>
            </div>
            <div class="risk-field risk-field-full">
                <label for="driver_signature_document">Firma y numero de cedula de Conductor</label>
                <input id="driver_signature_document" name="driver_signature_document" type="text" t-att-value="data.get('driver_signature_document') or data.get('driver_document_number')" inputmode="numeric" pattern="[0-9]{6,10}" title="Cedula de 6 a 10 digitos numericos" autocomplete="off"/>
            </div>
        </div>

        <div class="risk-signature-note">
            <strong>Nota:</strong> En caso de creacion de nuevo vehiculo, el propietario/tenedor debe firmar sin ninguna excepcion. Para los casos que se requiera cambio de conductor y este cuente con estudio vigente, tanto el propietario/tenedor y conductor deberan firmar sin ninguna excepcion.
        </div>
    </template>
</odoo>
