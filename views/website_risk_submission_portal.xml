<odoo>
    <template id="portal_risk_submission_list" name="Mis Solicitudes de Riesgo">
        <t t-call="website.layout">
            <main class="risk-portal-page">
                <section class="risk-brand-header risk-brand-header-compact" aria-label="Impocoma Riesgos">
                    <div class="risk-brand-mark">
                        <img src="/risk_module/static/src/img/impocoma_logo.jpeg" alt="Impocoma"/>
                    </div>
                    <div class="risk-brand-copy">
                        <p>Portal de terceros</p>
                        <h1>Mis solicitudes de riesgo</h1>
                        <span>Consulta el avance de tus registros y los documentos pendientes.</span>
                    </div>
                </section>

                <div class="risk-portal-toolbar">
                    <h2>Solicitudes registradas</h2>
                    <a href="/registro-conductor" class="btn btn-primary">Nueva solicitud</a>
                </div>
                <div t-if="not submissions" class="alert alert-info">
                    No tienes solicitudes registradas.
                </div>
                <div t-if="submissions" class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th>Placa</th>
                                <th>Fecha</th>
                                <th>Estado</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="submissions" t-as="submission">
                                <td><strong t-esc="submission.vehicle_plate"/></td>
                                <td t-esc="submission.form_date or ''"/>
                                <td><span class="badge text-bg-secondary" t-esc="submission.portal_state_label"/></td>
                                <td class="text-end">
                                    <a t-attf-href="/mis-solicitudes-riesgo/#{submission.id}" class="btn btn-sm btn-outline-primary">Ver detalle</a>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </main>
        </t>
    </template>

    <template id="portal_risk_submission_detail" name="Detalle Solicitud de Riesgo">
        <t t-call="website.layout">
            <main class="risk-portal-page">
                <section class="risk-brand-header risk-brand-header-compact" aria-label="Impocoma Riesgos">
                    <div class="risk-brand-mark">
                        <img src="/risk_module/static/src/img/impocoma_logo.jpeg" alt="Impocoma"/>
                    </div>
                    <div class="risk-brand-copy">
                        <p>Detalle de solicitud</p>
                        <h1>Solicitud <span t-esc="submission.vehicle_plate"/></h1>
                        <span t-esc="submission.name or 'Seguimiento documental'"/>
                    </div>
                </section>

                <div class="mb-4">
                    <a href="/mis-solicitudes-riesgo" class="btn btn-link px-0">Volver a mis solicitudes</a>
                </div>

                <div t-if="request.params.get('upload_success')" class="alert alert-success">
                    Documento cargado correctamente.
                </div>
                <div t-if="request.params.get('upload_error') == 'missing'" class="alert alert-danger">
                    Debes seleccionar un archivo para cargar.
                </div>
                <div t-if="request.params.get('upload_error') == 'not_allowed'" class="alert alert-warning">
                    La carga no esta habilitada para este documento en este momento.
                </div>
                <div t-if="request.params.get('upload_error') == 'too_large'" class="alert alert-danger">
                    El archivo supera el tamano maximo permitido de 10 MB.
                </div>
                <div t-if="request.params.get('upload_error') == 'invalid_type'" class="alert alert-danger">
                    Solo puedes cargar archivos PDF, JPG o PNG.
                </div>
                <div t-if="request.params.get('upload_error') == 'missing_issue_date'" class="alert alert-danger">
                    Debes indicar la fecha de expedicion del documento.
                </div>
                <div t-if="request.params.get('upload_error') == 'missing_expiration_date'" class="alert alert-danger">
                    Debes indicar la fecha de vencimiento del documento.
                </div>
                <div t-if="request.params.get('upload_error') == 'invalid_date'" class="alert alert-danger">
                    La fecha ingresada no es valida. Por favor revisala e intenta nuevamente.
                </div>
                <div t-if="request.params.get('upload_error') == 'expired_date'" class="alert alert-danger">
                    El documento se encuentra vencido. Por favor carga una version vigente.
                </div>
                <div t-if="request.params.get('upload_error') == 'old_issue_date'" class="alert alert-danger">
                    La fecha de expedicion supera la antiguedad maxima permitida para este documento.
                </div>

                <section class="mb-4">
                    <h2 class="h5">Estado</h2>
                    <p><span class="badge text-bg-secondary" t-esc="submission.portal_state_label"/></p>
                    <div t-if="submission.state == 'correction_required'" class="alert alert-warning">
                        <p class="mb-2">
                            Tu solicitud requiere correccion antes de continuar.
                        </p>
                        <p t-if="submission.correction_reason" class="mb-2">
                            <strong>Motivo:</strong>
                            <span t-esc="submission.correction_reason"/>
                        </p>
                        <p class="mb-3">
                            <strong>Secciones:</strong>
                            <span t-esc="submission._correction_section_labels()"/>
                        </p>
                        <a t-attf-href="/registro-conductor/corregir/#{submission.id}" class="btn btn-primary">
                            Corregir solicitud
                        </a>
                    </div>
                    <p t-if="submission.rejection_reason" class="alert alert-danger" t-esc="submission.rejection_reason"/>
                    <p t-if="submission.message" class="alert alert-light" t-esc="submission.message"/>
                </section>

                <section>
                    <h2 class="h5">Documentos solicitados</h2>
                    <t t-set="required_documents" t-value="submission.document_ids.filtered(lambda d: d.required)"/>
                    <div t-if="not required_documents" class="alert alert-info">
                        Aun no tienes documentos solicitados.
                    </div>
                    <div t-if="required_documents">
                        <t t-set="driver_documents" t-value="required_documents.filtered(lambda d: d.party == 'driver')"/>
                        <t t-set="vehicle_documents" t-value="required_documents.filtered(lambda d: d.party in ('vehicle', 'semi_trailer'))"/>
                        <t t-set="owner_documents" t-value="required_documents.filtered(lambda d: d.party == 'owner')"/>
                        <t t-set="other_documents" t-value="required_documents.filtered(lambda d: d.party not in ('driver', 'vehicle', 'semi_trailer', 'owner'))"/>

                        <div t-if="driver_documents">
                            <h3 class="h6">Conductor</h3>
                            <div class="list-group mb-3">
                                <div t-foreach="driver_documents.sorted('sequence')" t-as="document" class="list-group-item">
                                    <div class="d-flex justify-content-between gap-3">
                                        <div>
                                            <strong t-esc="document.name"/>
                                            <div class="text-muted small">
                                                Estado: <span t-esc="dict(document._fields['state'].selection).get(document.state)"/>
                                            </div>
                                            <div t-if="document.instructions" class="small" t-esc="document.instructions"/>
                                            <div class="small text-muted">
                                                <span t-if="document.requires_color" class="badge text-bg-light">A color</span>
                                                <span t-if="document.requires_both_sides" class="badge text-bg-light">Ambas caras</span>
                                                <span t-if="document.validity_required" class="badge text-bg-light">Vigente</span>
                                                <span t-if="document.issue_date_required" class="badge text-bg-light">Fecha expedicion</span>
                                                <span t-if="document.max_age_days" class="badge text-bg-light">Max. <t t-esc="document.max_age_days"/> dias</span>
                                            </div>
                                            <div t-if="document.observations" class="text-danger small" t-esc="document.observations"/>
                                        </div>
                                        <form t-if="submission._portal_document_upload_allowed(document)"
                                              t-attf-action="/mis-solicitudes-riesgo/#{submission.id}/documentos/#{document.id}/subir"
                                              method="post"
                                              enctype="multipart/form-data"
                                              class="risk-portal-upload-form d-flex align-items-end gap-2 flex-wrap">
                                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                            <label t-if="document.issue_date_required or document.max_age_days" class="small text-muted mb-0">
                                                Fecha de expedicion
                                                <input type="date" name="issue_date" class="form-control form-control-sm" required="required" t-att-value="document.issue_date or ''"/>
                                            </label>
                                            <label t-if="document.validity_required" class="small text-muted mb-0">
                                                Fecha de vencimiento
                                                <input type="date" name="expiration_date" class="form-control form-control-sm" required="required" t-att-value="document.expiration_date or ''"/>
                                            </label>
                                            <input type="file" name="document_file" class="form-control form-control-sm" required="required"/>
                                            <button type="submit" class="btn btn-sm btn-primary">Subir</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div t-if="vehicle_documents">
                            <h3 class="h6">Vehículo</h3>
                            <div class="list-group mb-3">
                                <div t-foreach="vehicle_documents.sorted('sequence')" t-as="document" class="list-group-item">
                                    <div class="d-flex justify-content-between gap-3">
                                        <div>
                                            <strong t-esc="document.name"/>
                                            <div class="text-muted small">
                                                Estado: <span t-esc="dict(document._fields['state'].selection).get(document.state)"/>
                                            </div>
                                            <div t-if="document.instructions" class="small" t-esc="document.instructions"/>
                                            <div class="small text-muted">
                                                <span t-if="document.requires_color" class="badge text-bg-light">A color</span>
                                                <span t-if="document.requires_both_sides" class="badge text-bg-light">Ambas caras</span>
                                                <span t-if="document.validity_required" class="badge text-bg-light">Vigente</span>
                                                <span t-if="document.issue_date_required" class="badge text-bg-light">Fecha expedicion</span>
                                                <span t-if="document.max_age_days" class="badge text-bg-light">Max. <t t-esc="document.max_age_days"/> dias</span>
                                            </div>
                                            <div t-if="document.observations" class="text-danger small" t-esc="document.observations"/>
                                        </div>
                                        <form t-if="submission._portal_document_upload_allowed(document)"
                                              t-attf-action="/mis-solicitudes-riesgo/#{submission.id}/documentos/#{document.id}/subir"
                                              method="post"
                                              enctype="multipart/form-data"
                                              class="risk-portal-upload-form d-flex align-items-end gap-2 flex-wrap">
                                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                            <label t-if="document.issue_date_required or document.max_age_days" class="small text-muted mb-0">
                                                Fecha de expedicion
                                                <input type="date" name="issue_date" class="form-control form-control-sm" required="required" t-att-value="document.issue_date or ''"/>
                                            </label>
                                            <label t-if="document.validity_required" class="small text-muted mb-0">
                                                Fecha de vencimiento
                                                <input type="date" name="expiration_date" class="form-control form-control-sm" required="required" t-att-value="document.expiration_date or ''"/>
                                            </label>
                                            <input type="file" name="document_file" class="form-control form-control-sm" required="required"/>
                                            <button type="submit" class="btn btn-sm btn-primary">Subir</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div t-if="owner_documents">
                            <h3 class="h6">Propietario o Tenedor (Persona natural)</h3>
                            <div class="list-group mb-3">
                                <div t-foreach="owner_documents.sorted('sequence')" t-as="document" class="list-group-item">
                                    <div class="d-flex justify-content-between gap-3">
                                        <div>
                                            <strong t-esc="document.name"/>
                                            <div class="text-muted small">
                                                Estado: <span t-esc="dict(document._fields['state'].selection).get(document.state)"/>
                                            </div>
                                            <div t-if="document.instructions" class="small" t-esc="document.instructions"/>
                                            <div class="small text-muted">
                                                <span t-if="document.requires_color" class="badge text-bg-light">A color</span>
                                                <span t-if="document.requires_both_sides" class="badge text-bg-light">Ambas caras</span>
                                                <span t-if="document.validity_required" class="badge text-bg-light">Vigente</span>
                                                <span t-if="document.issue_date_required" class="badge text-bg-light">Fecha expedicion</span>
                                                <span t-if="document.max_age_days" class="badge text-bg-light">Max. <t t-esc="document.max_age_days"/> dias</span>
                                            </div>
                                            <div t-if="document.observations" class="text-danger small" t-esc="document.observations"/>
                                        </div>
                                        <form t-if="submission._portal_document_upload_allowed(document)"
                                              t-attf-action="/mis-solicitudes-riesgo/#{submission.id}/documentos/#{document.id}/subir"
                                              method="post"
                                              enctype="multipart/form-data"
                                              class="risk-portal-upload-form d-flex align-items-end gap-2 flex-wrap">
                                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                            <label t-if="document.issue_date_required or document.max_age_days" class="small text-muted mb-0">
                                                Fecha de expedicion
                                                <input type="date" name="issue_date" class="form-control form-control-sm" required="required" t-att-value="document.issue_date or ''"/>
                                            </label>
                                            <label t-if="document.validity_required" class="small text-muted mb-0">
                                                Fecha de vencimiento
                                                <input type="date" name="expiration_date" class="form-control form-control-sm" required="required" t-att-value="document.expiration_date or ''"/>
                                            </label>
                                            <input type="file" name="document_file" class="form-control form-control-sm" required="required"/>
                                            <button type="submit" class="btn btn-sm btn-primary">Subir</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div t-if="other_documents">
                            <h3 class="h6">Otros documentos</h3>
                            <div class="list-group mb-3">
                                <div t-foreach="other_documents.sorted('sequence')" t-as="document" class="list-group-item">
                                    <div class="d-flex justify-content-between gap-3">
                                        <div>
                                            <strong t-esc="document.name"/>
                                            <div class="text-muted small">
                                                Estado: <span t-esc="dict(document._fields['state'].selection).get(document.state)"/>
                                            </div>
                                            <div t-if="document.instructions" class="small" t-esc="document.instructions"/>
                                            <div class="small text-muted">
                                                <span t-if="document.requires_color" class="badge text-bg-light">A color</span>
                                                <span t-if="document.requires_both_sides" class="badge text-bg-light">Ambas caras</span>
                                                <span t-if="document.validity_required" class="badge text-bg-light">Vigente</span>
                                                <span t-if="document.issue_date_required" class="badge text-bg-light">Fecha expedicion</span>
                                                <span t-if="document.max_age_days" class="badge text-bg-light">Max. <t t-esc="document.max_age_days"/> dias</span>
                                            </div>
                                            <div t-if="document.observations" class="text-danger small" t-esc="document.observations"/>
                                        </div>
                                        <form t-if="submission._portal_document_upload_allowed(document)"
                                              t-attf-action="/mis-solicitudes-riesgo/#{submission.id}/documentos/#{document.id}/subir"
                                              method="post"
                                              enctype="multipart/form-data"
                                              class="risk-portal-upload-form d-flex align-items-end gap-2 flex-wrap">
                                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                            <label t-if="document.issue_date_required or document.max_age_days" class="small text-muted mb-0">
                                                Fecha de expedicion
                                                <input type="date" name="issue_date" class="form-control form-control-sm" required="required" t-att-value="document.issue_date or ''"/>
                                            </label>
                                            <label t-if="document.validity_required" class="small text-muted mb-0">
                                                Fecha de vencimiento
                                                <input type="date" name="expiration_date" class="form-control form-control-sm" required="required" t-att-value="document.expiration_date or ''"/>
                                            </label>
                                            <input type="file" name="document_file" class="form-control form-control-sm" required="required"/>
                                            <button type="submit" class="btn btn-sm btn-primary">Subir</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </main>
        </t>
    </template>
</odoo>
