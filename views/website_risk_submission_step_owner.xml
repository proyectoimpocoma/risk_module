<odoo>
    <template id="register_driver_step_owner" name="Registro Vehiculo Paso Propietario">
        <div class="risk-owner-page">
            <section class="risk-owner-header">
                <div>
                    <h2 class="risk-owner-title">Información del Propietario</h2>
                    <p class="risk-owner-lead">Por favor, complete los datos legales del dueño del vehículo o de la empresa responsable.</p>
                </div>
                <div class="risk-owner-step-badge">Paso 2 de 4</div>
            </section>

            <div class="risk-owner-grid">
                <div class="risk-owner-form-card">
                    <div class="risk-owner-form-grid">
                        <div class="risk-field risk-field-full">
                            <label for="owner_name">Nombre Completo o Razón Social</label>
                            <input id="owner_name" name="owner_name" type="text" class="risk-owner-input" t-att-value="data.get('owner_name')" required="required" maxlength="140" minlength="3" autocomplete="off" placeholder="Ej: Transportes del Norte S.A.S"/>
                        </div>

                        <div class="risk-field">
                            <label>Tipo de Documento</label>
                            <div class="risk-choice-row">
                                <label class="risk-choice">
                                    <span>CC</span>
                                    <input type="radio" name="owner_document_type" value="cc" required="required" t-att-checked="'checked' if data.get('owner_document_type') == 'cc' else None"/>
                                </label>
                                <label class="risk-choice">
                                    <span>NIT</span>
                                    <input type="radio" name="owner_document_type" value="nit" t-att-checked="'checked' if data.get('owner_document_type') == 'nit' else None"/>
                                </label>
                            </div>
                        </div>

                        <div class="risk-field">
                            <label for="owner_document_number">Número de Documento</label>
                            <input id="owner_document_number" name="owner_document_number" type="text" class="risk-owner-input" t-att-value="data.get('owner_document_number')" required="required" maxlength="11" pattern="[0-9]{6,10}|[0-9]{9}-[0-9]" title="CC: 6 a 10 digitos. NIT: 123456789 o 123456789-0" autocomplete="off" placeholder="000.000.000-0"/>
                        </div>

                        <div class="risk-field risk-field-full">
                            <label for="owner_address">Dirección de Notificación</label>
                            <div class="risk-owner-input-wrapper">
                                <input id="owner_address" name="owner_address" type="text" class="risk-owner-input" t-att-value="data.get('owner_address')" maxlength="140" autocomplete="off" placeholder="Calle 123 # 45 - 67"/>
                                <span class="risk-owner-input-icon material-symbols-outlined">location_on</span>
                            </div>
                        </div>

                        <div class="risk-field">
                            <label for="owner_neighborhood">Barrio</label>
                            <input id="owner_neighborhood" name="owner_neighborhood" type="text" class="risk-owner-input" t-att-value="data.get('owner_neighborhood')" maxlength="80" autocomplete="off" placeholder="Ej: Fontibón"/>
                        </div>

                        <div class="risk-field">
                            <label for="owner_city">Ciudad / Municipio</label>
                            <input id="owner_city" name="owner_city" type="text" class="risk-owner-input" t-att-value="data.get('owner_city')" maxlength="80" autocomplete="off" placeholder="Ej: Bogotá D.C."/>
                        </div>

                        <div class="risk-field">
                            <label for="owner_phone">Teléfono de Contacto</label>
                            <input id="owner_phone" name="owner_phone" type="tel" class="risk-owner-input" t-att-value="data.get('owner_phone')" inputmode="numeric" pattern="[0-9 ()+-]{10,16}" title="Celular colombiano de 10 digitos que inicia por 3" autocomplete="off" placeholder="+57 300 000 0000"/>
                        </div>

                        <div class="risk-field">
                            <label for="owner_email">Correo Electrónico</label>
                            <input id="owner_email" name="owner_email" type="email" class="risk-owner-input" t-att-value="data.get('owner_email')" maxlength="120" autocomplete="off" placeholder="contacto@empresa.com"/>
                        </div>

                        <div class="risk-field risk-field-full">
                            <div class="risk-choice-row">
                                <span>Autorizo la entrega y pago de anticipos a</span>
                                <label class="risk-choice">
                                    <span>Conductor</span>
                                    <input type="radio" name="advance_payment_to" value="driver" t-att-checked="'checked' if data.get('advance_payment_to') == 'driver' else None"/>
                                </label>
                                <label class="risk-choice">
                                    <span>Propietario</span>
                                    <input type="radio" name="advance_payment_to" value="owner" t-att-checked="'checked' if data.get('advance_payment_to') == 'owner' else None"/>
                                </label>
                            </div>
                        </div>

                        <t t-set="registered_owner_required" t-value="data.get('same_owner_on_license') == 'no'"/>
                        <div class="risk-field risk-field-full risk-switch-card">
                            <div>
                                <span class="risk-switch-title">¿El propietario es el mismo de la licencia?</span>
                                <span class="risk-switch-help">Sincronizar automáticamente con los datos de tránsito.</span>
                            </div>
                            <label class="risk-switch" for="same_owner_on_license_toggle">
                                <span>No</span>
                                <input id="same_owner_on_license_toggle" type="checkbox" t-att-checked="'checked' if data.get('same_owner_on_license') != 'no' else None"/>
                                <span class="risk-switch-track" aria-hidden="true"></span>
                                <span>Sí</span>
                            </label>
                            <input id="same_owner_on_license" name="same_owner_on_license" type="hidden" t-att-value="data.get('same_owner_on_license') or 'yes'"/>
                        </div>

                        <p t-attf-class="risk-section-note risk-registered-owner-field #{'' if registered_owner_required else 'is-disabled'}" data-registered-owner-field="1">En caso de que su respuesta sea NO, por favor diligenciar la siguiente información del propietario:</p>

                        <div t-attf-class="risk-inline-doc risk-registered-owner-field #{'' if registered_owner_required else 'is-disabled'}" data-registered-owner-field="1">
                            <div></div>
                            <label class="risk-choice">
                                <span>CC</span>
                                <input type="radio" name="registered_owner_document_type" value="cc" t-att-disabled="None if registered_owner_required else 'disabled'" t-att-required="'required' if registered_owner_required else None" t-att-checked="'checked' if data.get('registered_owner_document_type') == 'cc' else None"/>
                            </label>
                            <label class="risk-choice">
                                <span>NIT</span>
                                <input type="radio" name="registered_owner_document_type" value="nit" t-att-disabled="None if registered_owner_required else 'disabled'" t-att-checked="'checked' if data.get('registered_owner_document_type') == 'nit' else None"/>
                            </label>
                            <div class="risk-field">
                                <label for="registered_owner_document_number">Número</label>
                                <input id="registered_owner_document_number" name="registered_owner_document_number" type="text" class="risk-owner-input" t-att-value="data.get('registered_owner_document_number')" t-att-disabled="None if registered_owner_required else 'disabled'" t-att-required="'required' if registered_owner_required else None" maxlength="11" pattern="[0-9]{6,10}|[0-9]{9}-[0-9]" title="CC: 6 a 10 digitos. NIT: 123456789 o 123456789-0" autocomplete="off" placeholder="Documento registrado"/>
                            </div>
                        </div>

                        <div t-attf-class="risk-field risk-registered-owner-field #{'' if registered_owner_required else 'is-disabled'}" data-registered-owner-field="1">
                            <label for="registered_owner_name">Nombres y apellidos</label>
                            <input id="registered_owner_name" name="registered_owner_name" type="text" class="risk-owner-input" t-att-value="data.get('registered_owner_name')" t-att-disabled="None if registered_owner_required else 'disabled'" t-att-required="'required' if registered_owner_required else None" maxlength="140" autocomplete="off" placeholder="Nombres y apellidos del propietario registrado"/>
                        </div>

                        <div t-attf-class="risk-field risk-registered-owner-field #{'' if registered_owner_required else 'is-disabled'}" data-registered-owner-field="1">
                            <label for="registered_owner_phone">Celular</label>
                            <input id="registered_owner_phone" name="registered_owner_phone" type="tel" class="risk-owner-input" t-att-value="data.get('registered_owner_phone')" t-att-disabled="None if registered_owner_required else 'disabled'" t-att-required="'required' if registered_owner_required else None" inputmode="numeric" pattern="[0-9 ()+-]{10,16}" title="Celular colombiano de 10 digitos que inicia por 3" autocomplete="off" placeholder="Ej: 3123456789"/>
                        </div>
                    </div>
                </div>

                <aside class="risk-owner-sidebar">
                    <div class="risk-card risk-card-primary">
                        <h3>Seguridad de Datos</h3>
                        <p>Toda la información proporcionada está protegida por nuestra política de tratamiento de datos personales y se utiliza exclusivamente para fines operativos de transporte de carga pesada.</p>
                        <div class="risk-card-helpers">
                            <div class="risk-card-helper">
                                <span class="material-symbols-outlined">check_circle</span>
                                <div>Encriptación SSL</div>
                            </div>
                            <div class="risk-card-helper">
                                <span class="material-symbols-outlined">check_circle</span>
                                <div>Cumplimiento Ley 1581</div>
                            </div>
                        </div>
                    </div>

                    <div class="risk-card risk-card-status">
                        <h3>Estado del Proceso</h3>
                        <div class="risk-status-item completed">
                            <span class="material-symbols-outlined">check</span>
                            <div>Datos del Vehículo</div>
                        </div>
                        <div class="risk-status-item current">
                            <span>2</span>
                            <div>Datos del Propietario</div>
                        </div>
                        <div class="risk-status-item upcoming">
                            <span>3</span>
                            <div>Documentación Técnica</div>
                        </div>
                        <div class="risk-status-item upcoming">
                            <span>4</span>
                            <div>Revisión Final</div>
                        </div>
                    </div>

                    <div class="risk-card risk-card-image">
                        <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuBjZcwWqAkPny3OxxGGPwPXEHPeO277wKgeN0vxUM852aElrRtbXcL9J4aKcNCe906CHNth2ENxdbSb6knSo7EiIrXuDTcNuldRulGdHwWtVNpNLxuknr4vDu0lRz06v75okI3hn85x-rMZhkwYV5vmCX5MTkQtjIpVEKzyO8o0YpXdtncfdSufo3NCyNfNLqu7G3QU4wQVjmieVx29-33tZ2EQZEVFq2-xlNjMMaHMb2qyX6CNJa2vYo2BkR2JPOdtzoPMrWIS0Jc" alt="Impocoma logística"/>
                        <div class="risk-card-image-caption">Impocoma S.A.S - Líderes en Carga Pesada</div>
                    </div>
                </aside>
            </div>
        </div>
    </template>
</odoo>
