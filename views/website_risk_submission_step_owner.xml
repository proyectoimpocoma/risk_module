<odoo>
    <template id="register_driver_step_owner" name="Registro Vehiculo Paso Propietario">
        <!-- Sección 1: Datos de Identificación del Propietario -->
        <div class="risk-inline-doc">
            <div class="risk-field">
                <label for="owner_name">Nombres y apellidos / Empresa</label>
                <input id="owner_name" name="owner_name" type="text" t-att-value="data.get('owner_name')" required="required" maxlength="140" minlength="3" autocomplete="off" placeholder="Ej: Juan Perez o Transportes XYZ"/>
            </div>
            <label class="risk-choice">
                <span>CC</span>
                <input type="radio" name="owner_document_type" value="cc" required="required" t-att-checked="'checked' if data.get('owner_document_type') == 'cc' else None"/>
            </label>
            <label class="risk-choice">
                <span>Nit</span>
                <input type="radio" name="owner_document_type" value="nit" t-att-checked="'checked' if data.get('owner_document_type') == 'nit' else None"/>
            </label>
            <div class="risk-field">
                <label for="owner_document_number">Numero</label>
                <input id="owner_document_number" name="owner_document_number" type="text" t-att-value="data.get('owner_document_number')" required="required" maxlength="11" pattern="[0-9]{6,10}(-[0-9])?" title="CC: 6 a 10 digitos. NIT: 123456789 o 123456789-0" autocomplete="off" placeholder="Solo numeros, sin puntos"/>
            </div>
        </div>

        <!-- Sección 2: Información de Contacto y Ubicación -->
        <div class="risk-field">
            <label for="owner_address">Direccion</label>
            <input id="owner_address" name="owner_address" type="text" t-att-value="data.get('owner_address')" maxlength="140" autocomplete="off" placeholder="Calle 123 #45-67"/>
        </div>
        <div class="risk-field">
            <label for="owner_neighborhood">Barrio</label>
            <input id="owner_neighborhood" name="owner_neighborhood" type="text" t-att-value="data.get('owner_neighborhood')" maxlength="80" autocomplete="off" placeholder="Barrio o zona"/>
        </div>
        <div class="risk-field">
            <label for="owner_city">Ciudad</label>
            <input id="owner_city" name="owner_city" type="text" t-att-value="data.get('owner_city')" maxlength="80" autocomplete="off" placeholder="Ciudad"/>
        </div>
        <div class="risk-field">
            <label for="owner_phone">Numero de celular para notificaciones y autorizaciones electronicas</label>
            <input id="owner_phone" name="owner_phone" type="tel" t-att-value="data.get('owner_phone')" inputmode="numeric" pattern="[0-9 ()+-]{10,16}" title="Celular colombiano de 10 digitos que inicia por 3" autocomplete="off" placeholder="Ej: 3123456789"/>
        </div>
        <div class="risk-field risk-field-full">
            <label for="owner_email">Correo electronico de facturacion y notificaciones</label>
            <input id="owner_email" name="owner_email" type="email" t-att-value="data.get('owner_email')" maxlength="120" autocomplete="off" placeholder="ejemplo@dominio.com"/>
        </div>

        <!-- Sección 3: Autorización de Pagos -->
        <div class="risk-choice-row">
            <span>Autorizo la entrega y pago de anticipos a</span>
            <label class="risk-choice">
                <span>Conductor</span>
                <input type="radio" name="advance_payment_to" value="driver" t-att-checked="'checked' if data.get('advance_payment_to') == 'driver' else None"/>
            </label>
            <label class="risk-choice">
                <span>Propietario</span>
                <input type="radio" name="advance_payment_to" value="owner" t-att-checked="'checked' if data.get('advance_payment_to') == 'owner' else None"/>
            </label>
        </div>

        <!-- Sección 4: Propietario Registrado en Licencia (Condicional) -->
        <t t-set="registered_owner_required" t-value="data.get('same_owner_on_license') == 'no'"/>
        <div class="risk-field risk-field-full risk-switch-card">
            <div>
                <span class="risk-switch-title">Propietario registrado en licencia</span>
                <span class="risk-switch-help">La informacion del tenedor o poseedor corresponde al mismo o unico propietario registrado en la Licencia de Transito?</span>
            </div>
            <label class="risk-switch" for="same_owner_on_license_toggle">
                <span>No</span>
                <input id="same_owner_on_license_toggle" type="checkbox" t-att-checked="'checked' if data.get('same_owner_on_license') != 'no' else None"/>
                <span class="risk-switch-track" aria-hidden="true"></span>
                <span>Si</span>
            </label>
            <input id="same_owner_on_license" name="same_owner_on_license" type="hidden" t-att-value="data.get('same_owner_on_license') or 'yes'"/>
        </div>

        <p t-attf-class="risk-section-note risk-registered-owner-field #{'' if registered_owner_required else 'is-disabled'}" data-registered-owner-field="1">En caso de que su respuesta sea NO, por favor diligenciar la siguiente informacion del propietario:</p>
        <div t-attf-class="risk-inline-doc risk-registered-owner-field #{'' if registered_owner_required else 'is-disabled'}" data-registered-owner-field="1">
            <div></div>
            <label class="risk-choice">
                <span>CC</span>
                <input type="radio" name="registered_owner_document_type" value="cc" t-att-disabled="None if registered_owner_required else 'disabled'" t-att-required="'required' if registered_owner_required else None" t-att-checked="'checked' if data.get('registered_owner_document_type') == 'cc' else None"/>
            </label>
            <label class="risk-choice">
                <span>Nit</span>
                <input type="radio" name="registered_owner_document_type" value="nit" t-att-disabled="None if registered_owner_required else 'disabled'" t-att-checked="'checked' if data.get('registered_owner_document_type') == 'nit' else None"/>
            </label>
            <div class="risk-field">
                <label for="registered_owner_document_number">Numero</label>
                <input id="registered_owner_document_number" name="registered_owner_document_number" type="text" t-att-value="data.get('registered_owner_document_number')" t-att-disabled="None if registered_owner_required else 'disabled'" t-att-required="'required' if registered_owner_required else None" maxlength="11" pattern="[0-9]{6,10}(-[0-9])?" title="CC: 6 a 10 digitos. NIT: 123456789 o 123456789-0" autocomplete="off" placeholder="Documento registrado"/>
            </div>
        </div>
        <div t-attf-class="risk-field risk-registered-owner-field #{'' if registered_owner_required else 'is-disabled'}" data-registered-owner-field="1">
            <label for="registered_owner_name">Nombres y apellidos</label>
            <input id="registered_owner_name" name="registered_owner_name" type="text" t-att-value="data.get('registered_owner_name')" t-att-disabled="None if registered_owner_required else 'disabled'" t-att-required="'required' if registered_owner_required else None" maxlength="140" autocomplete="off" placeholder="Nombres y apellidos del propietario registrado"/>
        </div>
        <div t-attf-class="risk-field risk-registered-owner-field #{'' if registered_owner_required else 'is-disabled'}" data-registered-owner-field="1">
            <label for="registered_owner_phone">Celular</label>
            <input id="registered_owner_phone" name="registered_owner_phone" type="tel" t-att-value="data.get('registered_owner_phone')" t-att-disabled="None if registered_owner_required else 'disabled'" t-att-required="'required' if registered_owner_required else None" inputmode="numeric" pattern="[0-9 ()+-]{10,16}" title="Celular colombiano de 10 digitos que inicia por 3" autocomplete="off" placeholder="Ej: 3123456789"/>
        </div>
    </template>
</odoo>
