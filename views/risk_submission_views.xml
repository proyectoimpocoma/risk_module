<odoo>
    <record id="view_risk_module_list" model="ir.ui.view">
        <field name="name">risk.module.list</field>
        <field name="model">risk.module</field>
        <field name="arch" type="xml">
            <list string="Solicitudes de Vehiculo"
                  decoration-success="state == 'approved'"
                  decoration-danger="state == 'rejected'"
                  decoration-info="state in ('submitted', 'risk_review', 'manual_approval_pending', 'documents_review')"
                  decoration-warning="state in ('draft', 'external_validation_pending', 'documents_requested')">
                <field name="create_date" string="Creado"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'approved'"
                       decoration-danger="state == 'rejected'"
                       decoration-info="state in ('submitted', 'risk_review', 'manual_approval_pending', 'documents_review')"
                       decoration-warning="state in ('draft', 'external_validation_pending', 'documents_requested')"/>
                <field name="form_date" string="Fecha"/>
                <field name="vehicle_plate" string="Placa"/>
                <field name="semi_trailer_plate" string="Semi/Remolque" optional="hide"/>
                <field name="owner_name" string="Propietario / Empresa"/>
                <field name="owner_city" string="Ciudad"/>
                <field name="driver_name" string="Conductor"/>
                <field name="satellite_company" string="Empresa Satelital" optional="hide"/>
                <button name="action_open_printable" type="object" string="PDF" icon="fa-print"/>
            </list>
        </field>
    </record>

    <record id="view_risk_module_form" model="ir.ui.view">
        <field name="name">risk.module.form</field>
        <field name="model">risk.module</field>
        <field name="arch" type="xml">
            <form string="Solicitud de Vehiculo">
                <header>
                    <button name="action_open_printable" type="object" string="Imprimir / Guardar PDF" class="btn-primary"/>
                    <button name="action_start_risk_review" type="object" string="Iniciar revision"
                            invisible="state != 'submitted'"/>
                    <button name="action_mark_external_validation_pending" type="object" string="Dejar validacion externa pendiente"
                            invisible="state != 'risk_review'"/>
                    <button name="action_skip_external_validation" type="object" string="Continuar a aprobacion manual"
                            invisible="state not in ('risk_review', 'external_validation_pending')"/>
                    <button name="action_request_documents" type="object" string="Solicitar documentos"
                            invisible="state != 'manual_approval_pending'"/>
                    <button name="action_start_document_review" type="object" string="Revisar documentos"
                            invisible="state != 'documents_requested'"/>
                    <button name="action_approve" type="object" string="Aprobar" class="btn-primary"
                            invisible="state not in ('manual_approval_pending', 'documents_review')"/>
                    <button name="action_reject" type="object" string="Rechazar"
                            invisible="state in ('approved', 'rejected')"/>
                    <button name="action_reset_to_submitted" type="object" string="Reabrir"
                            invisible="state not in ('approved', 'rejected')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,risk_review,external_validation_pending,manual_approval_pending,documents_requested,documents_review,approved,rejected"/>
                </header>
                <sheet>
                    <!-- Encabezado con datos clave -->
                    <div class="oe_title">
                        <h1>
                            <field name="vehicle_plate" placeholder="Placa del vehículo"/>
                        </h1>
                        <h2>
                            <field name="name" placeholder="Referencia"/>
                        </h2>
                    </div>

                    <group>
                        <group string="Información General">
                            <field name="form_date"/>
                            <field name="semi_trailer_plate"/>
                        </group>
                        <group string="Información Satelital">
                            <field name="satellite_company"/>
                            <field name="satellite_user"/>
                            <field name="satellite_password" password="True"/>
                        </group>
                    </group>

                    <notebook>
                        <!-- Pestaña 1: Propietario -->
                        <page string="Propietario / Tenedor" name="owner_page">
                            <group string="Datos del Propietario / Tenedor / Poseedor">
                                <group>
                                    <field name="owner_name"/>
                                    <field name="owner_document_type"/>
                                    <field name="owner_document_number"/>
                                    <field name="owner_address"/>
                                    <field name="owner_neighborhood"/>
                                </group>
                                <group>
                                    <field name="owner_city"/>
                                    <field name="owner_phone"/>
                                    <field name="owner_email"/>
                                    <field name="advance_payment_to"/>
                                    <field name="same_owner_on_license"/>
                                </group>
                            </group>
                            <group string="Propietario Registrado en Licencia"
                                   invisible="same_owner_on_license != 'no'">
                                <group>
                                    <field name="registered_owner_document_type"/>
                                    <field name="registered_owner_document_number"/>
                                </group>
                                <group>
                                    <field name="registered_owner_name"/>
                                    <field name="registered_owner_phone"/>
                                </group>
                            </group>
                        </page>

                        <!-- Pestaña 2: Conductor -->
                        <page string="Conductor" name="driver_page">
                            <group string="Datos del Conductor">
                                <group>
                                    <field name="driver_name"/>
                                    <field name="driver_document_number"/>
                                    <field name="driver_address"/>
                                    <field name="driver_neighborhood"/>
                                    <field name="driver_city"/>
                                </group>
                                <group>
                                    <field name="driver_phone"/>
                                    <field name="driver_optional_phone"/>
                                    <field name="driver_email"/>
                                    <field name="driver_is_fit"/>
                                    <field name="driver_is_trained"/>
                                </group>
                            </group>
                            <group string="Referencias del Conductor">
                                <group>
                                    <field name="family_reference_name"/>
                                    <field name="family_reference_relationship"/>
                                    <field name="family_reference_phone"/>
                                </group>
                                <group>
                                    <field name="cargo_reference_name"/>
                                    <field name="cargo_reference_phone"/>
                                </group>
                            </group>
                        </page>

                        <!-- Pestaña 3: Firmas y Términos -->
                        <page string="Firmas y Términos" name="signatures_page">
                            <group string="Aceptación de Términos">
                                <group>
                                    <field name="banking_info_accepted"/>
                                    <field name="compensation_accepted"/>
                                    <field name="personal_data_accepted"/>
                                </group>
                                <group>
                                    <field name="terms_accepted_at"/>
                                </group>
                            </group>
                            <group string="Firma Propietario">
                                <group>
                                    <field name="owner_has_valid_study"/>
                                    <field name="owner_signature_document"/>
                                    <field name="owner_signed_at"/>
                                </group>
                                <group>
                                    <field name="owner_signature" widget="image" nolabel="1"/>
                                </group>
                            </group>
                            <group string="Firma Conductor">
                                <group>
                                    <field name="driver_has_valid_study"/>
                                    <field name="driver_signature_document"/>
                                    <field name="driver_signed_at"/>
                                </group>
                                <group>
                                    <field name="driver_signature" widget="image" nolabel="1"/>
                                </group>
                            </group>
                        </page>

                        <!-- Pestaña 4: Trazabilidad -->
                        <page string="Trazabilidad" name="traceability_page">
                            <group string="Revision de Riesgo">
                                <field name="risk_reviewer_id"/>
                                <field name="risk_reviewed_at"/>
                            </group>
                            <group string="Aprobacion Manual">
                                <group>
                                    <field name="approval_user_id"/>
                                    <field name="approval_date"/>
                                </group>
                                <group>
                                    <field name="approval_note"/>
                                </group>
                            </group>
                            <group string="Rechazo Manual">
                                <group>
                                    <field name="rejection_user_id"/>
                                    <field name="rejection_date"/>
                                </group>
                                <group>
                                    <field name="rejection_reason"/>
                                </group>
                            </group>
                            <group string="Trazabilidad de Firma Propietario">
                                <field name="owner_signature_ip"/>
                                <field name="owner_signature_user_agent"/>
                            </group>
                            <group string="Trazabilidad de Firma Conductor">
                                <field name="driver_signature_ip"/>
                                <field name="driver_signature_user_agent"/>
                            </group>
                        </page>

                        <!-- Pestaña 5: Observaciones -->
                        <page string="Observaciones" name="notes_page">
                            <group>
                                <field name="message" nolabel="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_risk_module_search" model="ir.ui.view">
        <field name="name">risk.module.search</field>
        <field name="model">risk.module</field>
        <field name="arch" type="xml">
            <search string="Solicitudes de Vehiculo">
                <field name="vehicle_plate"/>
                <field name="semi_trailer_plate"/>
                <field name="satellite_company"/>
                <field name="owner_name"/>
                <field name="driver_name"/>
                <filter string="Con empresa satelital" name="has_satellite_company" domain="[('satellite_company', '!=', False)]"/>
            </search>
        </field>
    </record>

    <record id="action_risk_module_open_printable" model="ir.actions.server">
        <field name="name">Imprimir / Guardar PDF</field>
        <field name="model_id" ref="model_risk_module"/>
        <field name="binding_model_id" ref="model_risk_module"/>
        <field name="binding_type">action</field>
        <field name="state">code</field>
        <field name="code">
if records:
    action = records[0].action_open_printable()
        </field>
    </record>

</odoo>
