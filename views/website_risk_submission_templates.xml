<odoo>
    <template id="register_driver" name="Registro Vehiculo">
        <t t-call="website.layout">

            <main class="risk-step-page">
                <section class="risk-step-header">
                    <div class="risk-step-title">Hoja de Vida Habilitacion Terceros</div>
                    <div class="risk-step-meta">
                        <span>CODIGO: FO-RI-01</span>
                        <span>VERSION: 13</span>
                        <span>FECHA: 09/05/2026</span>
                    </div>
                </section>

                <div class="risk-progress" aria-label="Progreso">
                    <div t-attf-class="risk-progress-item #{'is-active' if step == 1 else 'is-done' if step &gt; 1 else ''}">1. Vehiculo</div>
                    <div t-attf-class="risk-progress-item #{'is-active' if step == 2 else 'is-done' if step &gt; 2 else ''}">2. Propietario</div>
                    <div t-attf-class="risk-progress-item #{'is-active' if step == 3 else 'is-done' if step &gt; 3 else ''}">3. Conductor</div>
                    <div t-attf-class="risk-progress-item #{'is-active' if step == 4 else 'is-done' if step &gt; 4 else ''}">4. Terminos</div>
                    <div t-attf-class="risk-progress-item #{'is-active' if step == 5 else 'is-done' if step &gt; 5 else ''}">5. Firmas</div>
                    <div t-attf-class="risk-progress-item #{'is-active' if step == 6 else ''}">6. Revision</div>
                </div>

                <form t-attf-action="/registro-conductor/submit/#{step}" method="post" class="risk-form">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                    <section class="risk-panel">
                        <div t-if="step == 1" class="risk-panel-title">Informacion del Vehiculo</div>
                        <div t-if="step == 2" class="risk-panel-title">Informacion del Propietario / Tenedor / Poseedor</div>
                        <div t-if="step == 3" class="risk-panel-title">Informacion del Conductor</div>
                        <div t-if="step == 4" class="risk-panel-title">Aceptacion de Terminos y Autorizaciones</div>
                        <div t-if="step == 5" class="risk-panel-title">Firmas</div>
                        <div t-if="step == 6" class="risk-panel-title">Revision de la Solicitud</div>
                        <div class="risk-fields">
                            <div t-if="data.get('step_error')" class="risk-error" t-esc="data.get('step_error')"/>
                            <t t-if="step == 1">
                                <div class="risk-field">
                                    <label for="form_date">Fecha</label>
                                    <input id="form_date" name="form_date" type="date" t-att-value="data.get('form_date')" required="required"/>
                                </div>
                                <div class="risk-field">
                                    <label for="vehicle_plate">Placa</label>
                                    <input id="vehicle_plate" name="vehicle_plate" type="text" t-att-value="data.get('vehicle_plate')" required="required" autocomplete="off" pattern="[A-Za-z]{3}[0-9]{2,3}" title="Formato valido: ABC123 para vehiculo/carga o ABC12 para motocicleta"/>
                                </div>
                                <div class="risk-field risk-field-full">
                                    <label for="semi_trailer_plate">Semi/Remolque</label>
                                    <input id="semi_trailer_plate" name="semi_trailer_plate" type="text" t-att-value="data.get('semi_trailer_plate')" autocomplete="off" pattern="[A-Za-z]{3}[0-9]{2,3}" title="Formato valido: ABC123 o ABC12"/>
                                </div>
                                <div class="risk-field">
                                    <label for="satellite_company">Empresa satelital</label>
                                    <input id="satellite_company" name="satellite_company" type="text" t-att-value="data.get('satellite_company')" maxlength="80" autocomplete="off"/>
                                </div>
                                <div class="risk-field">
                                    <label for="satellite_user">Usuario</label>
                                    <input id="satellite_user" name="satellite_user" type="text" t-att-value="data.get('satellite_user')" maxlength="80" autocomplete="off"/>
                                </div>
                                <div class="risk-field risk-field-full">
                                    <label for="satellite_password">Clave</label>
                                    <input id="satellite_password" name="satellite_password" type="password" t-att-value="data.get('satellite_password')" maxlength="80" autocomplete="off"/>
                                </div>
                            </t>

                            <t t-if="step == 2">
                                <div class="risk-inline-doc">
                                    <div class="risk-field">
                                        <label for="owner_name">Nombres y apellidos / Empresa</label>
                                        <input id="owner_name" name="owner_name" type="text" t-att-value="data.get('owner_name')" required="required" maxlength="140" minlength="3" autocomplete="off"/>
                                    </div>
                                    <label class="risk-choice">
                                        <span>CC</span>
                                        <input type="radio" name="owner_document_type" value="cc" required="required" t-att-checked="'checked' if data.get('owner_document_type') == 'cc' else None"/>
                                    </label>
                                    <label class="risk-choice">
                                        <span>Nit</span>
                                        <input type="radio" name="owner_document_type" value="nit" t-att-checked="'checked' if data.get('owner_document_type') == 'nit' else None"/>
                                    </label>
                                    <div class="risk-field">
                                        <label for="owner_document_number">Numero</label>
                                        <input id="owner_document_number" name="owner_document_number" type="text" t-att-value="data.get('owner_document_number')" required="required" maxlength="11" pattern="[0-9]{6,10}|[0-9]{9}-[0-9]" title="CC: 6 a 10 digitos. NIT: 123456789 o 123456789-0" autocomplete="off"/>
                                    </div>
                                </div>

                                <div class="risk-field">
                                    <label for="owner_address">Direccion</label>
                                    <input id="owner_address" name="owner_address" type="text" t-att-value="data.get('owner_address')" maxlength="140" autocomplete="off"/>
                                </div>
                                <div class="risk-field">
                                    <label for="owner_neighborhood">Barrio</label>
                                    <input id="owner_neighborhood" name="owner_neighborhood" type="text" t-att-value="data.get('owner_neighborhood')" maxlength="80" autocomplete="off"/>
                                </div>
                                <div class="risk-field">
                                    <label for="owner_city">Ciudad</label>
                                    <input id="owner_city" name="owner_city" type="text" t-att-value="data.get('owner_city')" maxlength="80" autocomplete="off"/>
                                </div>
                                <div class="risk-field">
                                    <label for="owner_phone">Numero de celular para notificaciones y autorizaciones electronicas</label>
                                    <input id="owner_phone" name="owner_phone" type="tel" t-att-value="data.get('owner_phone')" inputmode="numeric" pattern="[0-9 ()+-]{10,16}" title="Celular colombiano de 10 digitos que inicia por 3" autocomplete="off"/>
                                </div>
                                <div class="risk-field risk-field-full">
                                    <label for="owner_email">Correo electronico de facturacion y notificaciones</label>
                                    <input id="owner_email" name="owner_email" type="email" t-att-value="data.get('owner_email')" maxlength="120" autocomplete="off"/>
                                </div>

                                <div class="risk-choice-row">
                                    <span>Autorizo la entrega y pago de anticipos a</span>
                                    <label class="risk-choice">
                                        <span>Conductor</span>
                                        <input type="radio" name="advance_payment_to" value="driver" t-att-checked="'checked' if data.get('advance_payment_to') == 'driver' else None"/>
                                    </label>
                                    <label class="risk-choice">
                                        <span>Propietario</span>
                                        <input type="radio" name="advance_payment_to" value="owner" t-att-checked="'checked' if data.get('advance_payment_to') == 'owner' else None"/>
                                    </label>
                                </div>

                                <div class="risk-choice-row">
                                    <span>La informacion del tenedor o poseedor corresponde al mismo o unico propietario, registrado en la Licencia de Transito?</span>
                                    <label class="risk-choice">
                                        <span>SI</span>
                                        <input type="radio" name="same_owner_on_license" value="yes" t-att-checked="'checked' if data.get('same_owner_on_license') == 'yes' else None"/>
                                    </label>
                                    <label class="risk-choice">
                                        <span>NO</span>
                                        <input type="radio" name="same_owner_on_license" value="no" t-att-checked="'checked' if data.get('same_owner_on_license') == 'no' else None"/>
                                    </label>
                                </div>

                                <p class="risk-section-note">En caso de que su respuesta sea NO, por favor diligenciar la siguiente informacion del propietario:</p>
                                <div class="risk-inline-doc">
                                    <div></div>
                                    <label class="risk-choice">
                                        <span>CC</span>
                                        <input type="radio" name="registered_owner_document_type" value="cc" t-att-checked="'checked' if data.get('registered_owner_document_type') == 'cc' else None"/>
                                    </label>
                                    <label class="risk-choice">
                                        <span>Nit</span>
                                        <input type="radio" name="registered_owner_document_type" value="nit" t-att-checked="'checked' if data.get('registered_owner_document_type') == 'nit' else None"/>
                                    </label>
                                    <div class="risk-field">
                                        <label for="registered_owner_document_number">Numero</label>
                                        <input id="registered_owner_document_number" name="registered_owner_document_number" type="text" t-att-value="data.get('registered_owner_document_number')" maxlength="11" pattern="[0-9]{6,10}|[0-9]{9}-[0-9]" title="CC: 6 a 10 digitos. NIT: 123456789 o 123456789-0" autocomplete="off"/>
                                    </div>
                                </div>
                                <div class="risk-field">
                                    <label for="registered_owner_name">Nombres y apellidos</label>
                                    <input id="registered_owner_name" name="registered_owner_name" type="text" t-att-value="data.get('registered_owner_name')" maxlength="140" autocomplete="off"/>
                                </div>
                                <div class="risk-field">
                                    <label for="registered_owner_phone">Celular</label>
                                    <input id="registered_owner_phone" name="registered_owner_phone" type="tel" t-att-value="data.get('registered_owner_phone')" inputmode="numeric" pattern="[0-9 ()+-]{10,16}" title="Celular colombiano de 10 digitos que inicia por 3" autocomplete="off"/>
                                </div>
                            </t>

                            <t t-if="step == 3">
                                <div class="risk-field">
                                    <label for="driver_name">Nombres y apellidos</label>
                                    <input id="driver_name" name="driver_name" type="text" t-att-value="data.get('driver_name')" required="required" maxlength="140" minlength="3" autocomplete="off"/>
                                </div>
                                <div class="risk-field">
                                    <label for="driver_document_number">Numero de cedula</label>
                                    <input id="driver_document_number" name="driver_document_number" type="text" t-att-value="data.get('driver_document_number')" required="required" inputmode="numeric" pattern="[0-9]{6,10}" title="Cedula de 6 a 10 digitos numericos" autocomplete="off"/>
                                </div>
                                <div class="risk-field">
                                    <label for="driver_address">Direccion</label>
                                    <input id="driver_address" name="driver_address" type="text" t-att-value="data.get('driver_address')" maxlength="140" autocomplete="off"/>
                                </div>
                                <div class="risk-field">
                                    <label for="driver_neighborhood">Barrio</label>
                                    <input id="driver_neighborhood" name="driver_neighborhood" type="text" t-att-value="data.get('driver_neighborhood')" maxlength="80" autocomplete="off"/>
                                </div>
                                <div class="risk-field">
                                    <label for="driver_city">Ciudad</label>
                                    <input id="driver_city" name="driver_city" type="text" t-att-value="data.get('driver_city')" maxlength="80" autocomplete="off"/>
                                </div>
                                <div class="risk-field">
                                    <label for="driver_phone">Numero de celular para notificaciones y autorizaciones electronicas</label>
                                    <input id="driver_phone" name="driver_phone" type="tel" t-att-value="data.get('driver_phone')" inputmode="numeric" pattern="[0-9 ()+-]{10,16}" title="Celular colombiano de 10 digitos que inicia por 3" autocomplete="off"/>
                                </div>
                                <div class="risk-field">
                                    <label for="driver_optional_phone">Telefono opcional</label>
                                    <input id="driver_optional_phone" name="driver_optional_phone" type="tel" t-att-value="data.get('driver_optional_phone')" inputmode="numeric" pattern="[0-9 ()+-]{7,16}" title="Telefono de 7 digitos o 10 digitos iniciando por 3 o 6" autocomplete="off"/>
                                </div>
                                <div class="risk-field risk-field-full">
                                    <label for="driver_email">Correo electronico de autorizacion para notificaciones</label>
                                    <input id="driver_email" name="driver_email" type="email" t-att-value="data.get('driver_email')" maxlength="120" autocomplete="off"/>
                                </div>

                                <div class="risk-choice-row">
                                    <span>Se declara fisica, mental y psicotecnicamente apto para prestar sus servicios?</span>
                                    <label class="risk-choice">
                                        <span>SI</span>
                                        <input type="radio" name="driver_is_fit" value="yes" required="required" t-att-checked="'checked' if data.get('driver_is_fit') == 'yes' else None"/>
                                    </label>
                                    <label class="risk-choice">
                                        <span>NO</span>
                                        <input type="radio" name="driver_is_fit" value="no" t-att-checked="'checked' if data.get('driver_is_fit') == 'no' else None"/>
                                    </label>
                                </div>
                                <div class="risk-choice-row">
                                    <span>Esta capacitado y entrenado para contingencias y prevencion de accidentes por carreteras?</span>
                                    <label class="risk-choice">
                                        <span>SI</span>
                                        <input type="radio" name="driver_is_trained" value="yes" required="required" t-att-checked="'checked' if data.get('driver_is_trained') == 'yes' else None"/>
                                    </label>
                                    <label class="risk-choice">
                                        <span>NO</span>
                                        <input type="radio" name="driver_is_trained" value="no" t-att-checked="'checked' if data.get('driver_is_trained') == 'no' else None"/>
                                    </label>
                                </div>

                                <div class="risk-field">
                                    <label for="family_reference_name">Referencia familiar</label>
                                    <input id="family_reference_name" name="family_reference_name" type="text" t-att-value="data.get('family_reference_name')" maxlength="140" autocomplete="off"/>
                                </div>
                                <div class="risk-field">
                                    <label for="family_reference_relationship">Parentesco</label>
                                    <input id="family_reference_relationship" name="family_reference_relationship" type="text" t-att-value="data.get('family_reference_relationship')" maxlength="80" autocomplete="off"/>
                                </div>
                                <div class="risk-field">
                                    <label for="family_reference_phone">Celular</label>
                                    <input id="family_reference_phone" name="family_reference_phone" type="tel" t-att-value="data.get('family_reference_phone')" inputmode="numeric" pattern="[0-9 ()+-]{10,16}" title="Celular colombiano de 10 digitos que inicia por 3" autocomplete="off"/>
                                </div>
                                <div class="risk-field">
                                    <label for="cargo_reference_name">Referencia transporte de carga</label>
                                    <input id="cargo_reference_name" name="cargo_reference_name" type="text" t-att-value="data.get('cargo_reference_name')" maxlength="140" autocomplete="off"/>
                                </div>
                                <div class="risk-field">
                                    <label for="cargo_reference_phone">Celular</label>
                                    <input id="cargo_reference_phone" name="cargo_reference_phone" type="tel" t-att-value="data.get('cargo_reference_phone')" inputmode="numeric" pattern="[0-9 ()+-]{10,16}" title="Celular colombiano de 10 digitos que inicia por 3" autocomplete="off"/>
                                </div>
                            </t>

                            <t t-if="step == 4">
                                <div t-if="data.get('terms_error')" class="risk-error" t-esc="data.get('terms_error')"/>
                                <div class="risk-terms-card">
                                    <h3>Informacion bancaria</h3>
                                    <p>Se certifica que la cuenta bancaria entregada es vigente, esta libre de embargos o cualquier limitacion para su manejo y exonera a IMPOCOMA S.A.S. por cualquier eventualidad presentada con la cuenta bancaria.</p>
                                </div>
                                <div class="risk-terms-card">
                                    <h3>Autorizacion de compensacion general</h3>
                                    <p>Autoriza a IMPOCOMA S.A.S. a efectuar la compensacion prevista por saldos, novedades, faltantes, averias, saqueos, hurtos, contaminacion, anticipos no utilizados y demas eventos presentados durante la operacion del transporte.</p>
                                </div>
                                <div class="risk-terms-card">
                                    <h3>Autorizacion de datos personales</h3>
                                    <p>Autoriza la recoleccion, consulta, validacion, almacenamiento, uso, procesamiento, transferencia, transmision y tratamiento de datos personales para las finalidades relacionadas con la vinculacion y operacion.</p>
                                </div>
                                <div class="risk-field risk-field-full">
                                    <button type="button" class="btn btn-secondary" id="risk-open-terms">Ver terminos completos</button>
                                </div>
                                <label class="risk-terms-accept">
                                    <input id="risk-terms-confirmed" type="hidden" name="terms_accepted" t-att-value="'1' if data.get('terms_accepted') == '1' else '0'"/>
                                    <input id="risk-terms-check" type="checkbox" t-att-checked="'checked' if data.get('terms_accepted') == '1' else None" t-att-disabled="None if data.get('terms_accepted') == '1' else 'disabled'"/>
                                    <span>He leido los terminos completos y acepto la informacion bancaria, la autorizacion de compensacion general y la autorizacion de datos personales.</span>
                                </label>
                            </t>

                            <t t-if="step == 5">
                                <div t-if="data.get('signature_error')" class="risk-error" t-esc="data.get('signature_error')"/>
                                <div class="risk-signature-card">
                                    <h3>Propietario / Tenedor / Representante Legal</h3>
                                    <p>Si el propietario cuenta con estudio vigente, no debe diligenciar el siguiente espacio.</p>
                                    <div class="risk-choice-row">
                                        <span>Cuenta con estudio vigente?</span>
                                        <label class="risk-choice">
                                            <span>SI</span>
                                            <input type="radio" name="owner_has_valid_study" value="yes" t-att-checked="'checked' if data.get('owner_has_valid_study') == 'yes' else None"/>
                                        </label>
                                        <label class="risk-choice">
                                            <span>NO</span>
                                            <input type="radio" name="owner_has_valid_study" value="no" t-att-checked="'checked' if data.get('owner_has_valid_study') != 'yes' else None"/>
                                        </label>
                                    </div>
                                    <div class="risk-signature-pad" data-signature-pad="owner">
                                        <canvas id="owner-signature-canvas" width="720" height="190"></canvas>
                                        <input id="owner-signature-input" type="hidden" name="owner_signature" t-att-value="'data:image/png;base64,%s' % data.get('owner_signature') if data.get('owner_signature') else ''"/>
                                        <button type="button" class="btn btn-secondary risk-clear-signature" data-clear-signature="owner">Limpiar firma</button>
                                    </div>
                                    <div class="risk-field risk-field-full">
                                        <label for="owner_signature_document">Firma y numero de cedula</label>
                                        <input id="owner_signature_document" name="owner_signature_document" type="text" t-att-value="data.get('owner_signature_document') or data.get('owner_document_number')" inputmode="numeric" pattern="[0-9]{6,10}" title="Cedula de 6 a 10 digitos numericos" autocomplete="off"/>
                                    </div>
                                </div>

                                <div class="risk-signature-card">
                                    <h3>Conductor</h3>
                                    <p>Si el conductor cuenta con estudio vigente, no debe diligenciar el siguiente espacio.</p>
                                    <div class="risk-choice-row">
                                        <span>Cuenta con estudio vigente?</span>
                                        <label class="risk-choice">
                                            <span>SI</span>
                                            <input type="radio" name="driver_has_valid_study" value="yes" t-att-checked="'checked' if data.get('driver_has_valid_study') == 'yes' else None"/>
                                        </label>
                                        <label class="risk-choice">
                                            <span>NO</span>
                                            <input type="radio" name="driver_has_valid_study" value="no" t-att-checked="'checked' if data.get('driver_has_valid_study') != 'yes' else None"/>
                                        </label>
                                    </div>
                                    <div class="risk-signature-pad" data-signature-pad="driver">
                                        <canvas id="driver-signature-canvas" width="720" height="190"></canvas>
                                        <input id="driver-signature-input" type="hidden" name="driver_signature" t-att-value="'data:image/png;base64,%s' % data.get('driver_signature') if data.get('driver_signature') else ''"/>
                                        <button type="button" class="btn btn-secondary risk-clear-signature" data-clear-signature="driver">Limpiar firma</button>
                                    </div>
                                    <div class="risk-field risk-field-full">
                                        <label for="driver_signature_document">Firma y numero de cedula de Conductor</label>
                                        <input id="driver_signature_document" name="driver_signature_document" type="text" t-att-value="data.get('driver_signature_document') or data.get('driver_document_number')" inputmode="numeric" pattern="[0-9]{6,10}" title="Cedula de 6 a 10 digitos numericos" autocomplete="off"/>
                                    </div>
                                </div>

                                <div class="risk-signature-note">
                                    <strong>Nota:</strong> En caso de creacion de nuevo vehiculo, el propietario/tenedor debe firmar sin ninguna excepcion. Para los casos que se requiera cambio de conductor y este cuente con estudio vigente, tanto el propietario/tenedor y conductor deberan firmar sin ninguna excepcion.
                                </div>
                            </t>

                            <t t-if="step == 6">
                                <input type="hidden" name="terms_accepted" value="1"/>
                                <input type="hidden" name="owner_has_valid_study" t-att-value="data.get('owner_has_valid_study')"/>
                                <input type="hidden" name="owner_signature" t-att-value="data.get('owner_signature')"/>
                                <input type="hidden" name="owner_signature_document" t-att-value="data.get('owner_signature_document')"/>
                                <input type="hidden" name="driver_has_valid_study" t-att-value="data.get('driver_has_valid_study')"/>
                                <input type="hidden" name="driver_signature" t-att-value="data.get('driver_signature')"/>
                                <input type="hidden" name="driver_signature_document" t-att-value="data.get('driver_signature_document')"/>
                                <div class="risk-field risk-field-full">
                                    <div class="risk-print-toolbar">
                                        <button t-if="print_url" type="button" class="btn btn-secondary" id="risk-print-preview">Imprimir / Guardar como PDF</button>
                                        <a t-if="print_url" t-att-href="print_url" target="_blank" class="btn btn-secondary">Abrir vista imprimible</a>
                                    </div>
                                    <div t-if="print_url" class="risk-print-preview">
                                        <iframe id="risk-print-frame" t-att-src="print_url" title="Vista imprimible Hoja de Vida"/>
                                    </div>
                                    <div t-if="not print_url" class="risk-error">
                                        No se pudo generar la vista imprimible. Vuelve al paso de firmas y continua nuevamente.
                                    </div>
                                </div>
                                <div class="risk-field risk-field-full">
                                    <label for="message">Observaciones</label>
                                    <textarea id="message" name="message" placeholder="Observaciones adicionales"><t t-esc="data.get('message') or ''"/></textarea>
                                </div>
                            </t>
                        </div>
                    </section>

                    <div class="risk-actions">
                        <a t-if="step &gt; 1" t-attf-href="/registro-conductor/#{step - 1}" class="btn btn-secondary">Anterior</a>
                        <span t-if="step == 1"></span>
                        <button t-att-disabled="'disabled' if step == 4 else None" type="submit" class="btn btn-primary" id="risk-submit-button">
                            <t t-if="step &lt; 6">Siguiente</t>
                            <t t-if="step == 6">Enviar</t>
                        </button>
                    </div>
                </form>

                <t t-if="step == 4">
                    <div class="risk-modal" id="risk-terms-modal" role="dialog" aria-modal="true" aria-labelledby="risk-terms-title">
                        <div class="risk-modal-dialog">
                            <div class="risk-modal-header">
                                <h2 id="risk-terms-title">Terminos y autorizaciones completas</h2>
                                <button type="button" class="risk-modal-close" id="risk-close-terms" aria-label="Cerrar">x</button>
                            </div>
                            <div class="risk-modal-body">
                                <h3>Informacion bancaria</h3>
                                <p>Se certifica que la cuenta bancaria entregada es vigente, esta libre de embargos o cualquier limitacion para su manejo y exonera a IMPOCOMA S.A.S., por cualquier eventualidad presentada con la cuenta bancaria y que se hace responsable por ello.</p>

