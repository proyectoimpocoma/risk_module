<odoo>
    <record id="view_risk_module_form" model="ir.ui.view">
        <field name="name">risk.module.form</field>
        <field name="model">risk.module</field>
        <field name="arch" type="xml">
            <form string="Solicitud de Vehiculo">
                <header>
                    <button name="action_open_printable" type="object" string="Imprimir / Guardar PDF" class="btn-primary"/>
                    <button name="action_start_risk_review" type="object" string="Iniciar revision"
                            invisible="state not in ('submitted', 'correction_submitted')"/>
                    <button name="action_mark_external_validation_pending" type="object" string="Dejar validacion externa pendiente"
                            invisible="state != 'risk_review'"/>
                    <button name="action_send_external_validation" type="object" string="Enviar a Validiti"
                            invisible="state != 'external_validation_pending'"/>
                    <button name="action_register_external_validation_result" type="object" string="Registrar resultado Validiti"
                            invisible="state != 'external_validation_pending'"
                            groups="risk_module.group_risk_user"/>
                    <button name="action_skip_external_validation" type="object" string="Continuar a aprobacion manual"
                            invisible="state not in ('risk_review', 'external_validation_pending')"
                            groups="risk_module.group_risk_user"/>
                    <button name="action_request_documents" type="object" string="Solicitar documentos"
                            invisible="state != 'manual_approval_pending'"
                            groups="risk_module.group_risk_user"/>
                    <button name="action_start_document_review" type="object" string="Revisar documentos"
                            invisible="state != 'documents_requested'"/>
                    <button name="action_add_manual_document" type="object" string="Solicitar documento adicional"
                            invisible="state not in ('manual_approval_pending', 'documents_requested', 'documents_review')"
                            groups="risk_module.group_risk_user"/>
                    <button name="action_approve" type="object" string="Aprobar" class="btn-primary"
                            invisible="state != 'documents_review'"
                            groups="risk_module.group_risk_user"/>
                    <button name="action_reject" type="object" string="Rechazar"
                            invisible="state in ('approved', 'rejected')"
                            groups="risk_module.group_risk_user"/>
                    <button name="action_request_correction" type="object" string="Solicitar correccion"
                            invisible="state in ('draft', 'correction_required', 'approved', 'rejected')"
                            groups="risk_module.group_risk_user"/>
                    <button name="action_reset_to_submitted" type="object" string="Reabrir"
                            invisible="state not in ('approved', 'rejected')"
                            groups="risk_module.group_risk_user"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="submitted,risk_review,external_validation_pending,manual_approval_pending,documents_requested,documents_review,correction_required,correction_submitted,approved,rejected"/>
                </header>
                <sheet>
                    <!-- Encabezado con datos clave -->
                    <div class="oe_title">
                        <h1>
                            <field name="vehicle_plate" placeholder="Placa del vehículo"/>
                        </h1>
                        <h2>
                            <field name="name" placeholder="Referencia interna o número de solicitud"/>
                        </h2>
                    </div>

                    <div class="alert alert-info" role="status" invisible="state != 'submitted'">
                        <strong>Guia del flujo:</strong>
                        La solicitud fue enviada por el tercero. Inicia la revision para validar datos generales, propietario, conductor, vehiculo y firmas.
                    </div>
                    <div class="alert alert-info" role="status" invisible="state != 'risk_review'">
                        <strong>Guia del flujo:</strong>
                        Revisa el formulario. Desde aqui puedes enviar a validacion externa, continuar a aprobacion manual, solicitar correccion o rechazar definitivamente.
                    </div>
                    <div class="alert alert-info" role="status" invisible="state != 'external_validation_pending'">
                        <strong>Guia del flujo:</strong>
                        Gestiona la validacion externa. Registra el resultado o continua manualmente si aplica.
                    </div>
                    <div class="alert alert-info" role="status" invisible="state != 'manual_approval_pending'">
                        <strong>Guia del flujo:</strong>
                        Decide si apruebas, solicitas documentos, devuelves para correccion o rechazas definitivamente.
                    </div>
                    <div class="alert alert-warning" role="status" invisible="state != 'documents_requested'">
                        <strong>Guia del flujo:</strong>
                        Los documentos fueron solicitados al tercero. Espera las cargas del portal o agrega documentos adicionales si hace falta.
                    </div>
                    <div class="alert alert-info" role="status" invisible="state != 'documents_review'">
                        <strong>Guia del flujo:</strong>
                        Revisa y aprueba cada documento obligatorio. Si un documento esta mal, rechaza solo ese documento para que el tercero lo reemplace.
                    </div>
                    <div class="alert alert-warning" role="status" invisible="state != 'correction_required'">
                        <strong>Guia del flujo:</strong>
                        La solicitud fue devuelta al tercero. Espera a que corrija el formulario desde el portal y lo envie nuevamente.
                    </div>
                    <div class="alert alert-info" role="status" invisible="state != 'correction_submitted'">
                        <strong>Guia del flujo:</strong>
                        El tercero envio correcciones. Inicia revision para validar los cambios antes de continuar el flujo.
                    </div>
                    <div class="alert alert-success" role="status" invisible="state != 'approved'">
                        <strong>Guia del flujo:</strong>
                        Solicitud aprobada. El proceso queda finalizado salvo que un lider decida reabrirlo.
                    </div>
                    <div class="alert alert-danger" role="status" invisible="state != 'rejected'">
                        <strong>Guia del flujo:</strong>
                        Solicitud rechazada definitivamente. El tercero no puede corregir esta solicitud desde el portal.
                    </div>

                    <group>
                        <group string="Información General">
                            <field name="form_date"/>
                            <field name="semi_trailer_plate" placeholder="Placa del semirremolque"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="portal_user_id" readonly="1"/>
                            <field name="submitted_by_id" readonly="1"/>
                            <field name="vehicle_id" readonly="1"/>
                            <field name="driver_id" readonly="1"/>
                            <field name="owner_id" readonly="1"/>
                            <field name="vehicle_owner_link_id" readonly="1"/>
                            <field name="submission_email_status" readonly="1"/>
                            <field name="submission_email_sent_to" readonly="1"/>
                            <field name="submission_email_sent_at" readonly="1"/>
                            <field name="risk_reviewer_id" readonly="1"/>
                        </group>
                        <group string="Información Satelital">
                            <field name="satellite_company" placeholder="Empresa satelital"/>
                            <field name="satellite_user" placeholder="Usuario satelital"/>
                            <field name="satellite_password" password="True" placeholder="Contraseña satelital"/>
                        </group>
                    </group>

                    <notebook>
                        <!-- Pestaña 1: Propietario -->
                        <page string="Propietario / Tenedor" name="owner_page">
                            <group string="Datos del Propietario / Tenedor / Poseedor">
                                <group>
                                    <field name="owner_name" placeholder="Nombre completo del propietario"/>
                                    <field name="owner_document_type"/>
                                    <field name="owner_document_number" placeholder="Número del documento"/>
                                    <field name="owner_address" placeholder="Dirección completa"/>
                                    <field name="owner_neighborhood" placeholder="Barrio o zona"/>
                                </group>
                                <group>
                                    <field name="owner_city" placeholder="Ciudad"/>
                                    <field name="owner_phone" placeholder="Teléfono principal"/>
                                    <field name="owner_email" placeholder="Correo electrónico"/>
                                    <field name="advance_payment_to" placeholder="Persona o cuenta de pago"/>
                                    <field name="same_owner_on_license" widget="radio"/>
                                </group>
                            </group>
                            <group string="Propietario Registrado en Licencia"
                                   invisible="same_owner_on_license != 'no'">
                                <group>
                                    <field name="registered_owner_document_type"/>
                                    <field name="registered_owner_document_number" placeholder="Documento del propietario registrado"/>
                                </group>
                                <group>
                                    <field name="registered_owner_name" placeholder="Nombre registrado en la licencia"/>
                                    <field name="registered_owner_phone" placeholder="Teléfono del propietario registrado"/>
                                </group>
                            </group>
                        </page>

                        <!-- Pestaña 2: Conductor -->
                        <page string="Conductor" name="driver_page">
                            <group string="Datos del Conductor">
                                <group>
                                    <field name="driver_name" placeholder="Nombre completo del conductor"/>
                                    <field name="driver_document_number" placeholder="Documento del conductor"/>
                                    <field name="driver_address" placeholder="Dirección del conductor"/>
                                    <field name="driver_neighborhood" placeholder="Barrio del conductor"/>
                                    <field name="driver_city" placeholder="Ciudad del conductor"/>
                                </group>
                                <group>
                                    <field name="driver_phone" placeholder="Teléfono principal"/>
                                    <field name="driver_optional_phone" placeholder="Teléfono secundario (opcional)"/>
                                    <field name="driver_email" placeholder="Correo electrónico del conductor"/>
                                    <field name="driver_is_fit" widget="radio"/>
                                    <field name="driver_is_trained" widget="radio"/>
                                </group>
                            </group>
                            <group string="Referencias del Conductor">
                                <group>
                                    <field name="family_reference_name" placeholder="Nombre de referencia familiar"/>
                                    <field name="family_reference_relationship" placeholder="Parentesco"/>
                                    <field name="family_reference_phone" placeholder="Teléfono referencia familiar"/>
                                </group>
                                <group>
                                    <field name="cargo_reference_name" placeholder="Nombre referencia laboral"/>
                                    <field name="cargo_reference_phone" placeholder="Teléfono referencia laboral"/>
                                </group>
                            </group>
                        </page>

                        <!-- Pestaña 3: Firmas y Términos -->
                        <page string="Firmas y Términos" name="signatures_page">
                            <group string="Aceptación de Términos">
                                <group>
                                    <field name="single_owner_driver_signature"/>
                                    <field name="banking_info_accepted" widget="boolean_button"/>
                                    <field name="compensation_accepted" widget="boolean_button"/>
                                    <field name="personal_data_accepted" widget="boolean_button"/>
                                </group>
                                <group>
                                    <field name="terms_accepted_at"/>
                                </group>
                            </group>
                            <group string="Firma Propietario">
                                <group>
                                    <field name="owner_has_valid_study" widget="radio"/>
                                    <field name="owner_signature_document" placeholder="Documento que respalda la firma"/>
                                    <field name="owner_signed_at"/>
                                    <field name="owner_signature_verification_state" readonly="1"/>
                                    <field name="owner_signature_email" readonly="1"/>
                                    <field name="owner_signature_verified_at" readonly="1"/>
                                </group>
                                <group>
                                    <field name="owner_signature" widget="image" nolabel="1"/>
                                </group>
                            </group>
                            <group string="Firma Conductor">
                                <group>
                                    <field name="driver_has_valid_study" widget="radio"/>
                                    <field name="driver_signature_document" placeholder="Documento que respalda la firma"/>
                                    <field name="driver_signed_at"/>
                                    <field name="driver_signature_verification_state" readonly="1"/>
                                    <field name="driver_signature_email" readonly="1"/>
                                    <field name="driver_signature_verified_at" readonly="1"/>
                                </group>
                                <group>
                                    <field name="driver_signature" widget="image" nolabel="1"/>
                                </group>
                            </group>
                        </page>

                        <page string="Documentos" name="documents_page">
                            <group string="Resumen documental" class="risk_document_summary">
                                <group>
                                    <field name="document_progress_label" readonly="1"/>
                                    <field name="document_required_count" readonly="1"/>
                                    <field name="document_pending_count" readonly="1"/>
                                </group>
                                <group>
                                    <field name="document_received_count" readonly="1"/>
                                    <field name="document_approved_count" readonly="1"/>
                                    <field name="document_rejected_count" readonly="1"/>
                                </group>
                            </group>
                            <field name="document_ids" context="{'default_submission_id': id}">
                                <list string="Documentos"
                                      decoration-success="state == 'approved'"
                                      decoration-danger="state == 'rejected'"
                                      decoration-info="state == 'received'"
                                      decoration-muted="expiration_state == 'no_date'"
                                      decoration-warning="state == 'pending'">
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'approved'"
                                           decoration-danger="state == 'rejected'"
                                           decoration-info="state == 'received'"
                                           decoration-warning="state == 'pending'"/>
                                    <field name="name" string="Documento"/>
                                    <field name="party" string="Persona / Vehiculo"/>
                                    <field name="source" string="Origen"/>
                                    <field name="required" string="Obligatorio"/>
                                    <field name="filename" string="Archivo"/>
                                    <field name="uploaded_at" string="Cargado"/>
                                    <field name="issue_date" string="Expedicion"/>
                                    <field name="expiration_date" string="Vencimiento"/>
                                    <field name="expiration_state" widget="badge" string="Vigencia"
                                           decoration-success="expiration_state == 'valid'"
                                           decoration-warning="expiration_state == 'expiring'"
                                           decoration-danger="expiration_state == 'expired'"
                                           decoration-muted="expiration_state == 'no_date'"/>
                                    <field name="rejection_reason" string="Motivo"/>
                                    <field name="observations" string="Observaciones"/>
                                    <button name="action_open_document_preview" type="object" string="Ver PDF"
                                            invisible="not file"/>
                                    <button name="action_mark_received" type="object" string="Recibido"
                                            invisible="state != 'pending'"/>
                                    <button name="action_approve" type="object" string="Aprobar"
                                            invisible="state not in ('received', 'rejected')"/>
                                    <button name="action_reject" type="object" string="Rechazar"
                                            invisible="state not in ('received', 'approved')"/>
                                </list>
                                <form string="Documento">
                                    <header>
                                        <button name="action_open_file" type="object" string="Abrir archivo"
                                                class="btn-secondary" invisible="not file"/>
                                        <button name="action_mark_received" type="object" string="Marcar recibido"
                                                invisible="state != 'pending'"/>
                                        <button name="action_approve" type="object" string="Aprobar" class="btn-primary"
                                                invisible="state not in ('received', 'rejected')"/>
                                        <button name="action_reject" type="object" string="Rechazar"
                                                invisible="state not in ('received', 'approved')"/>
                                        <field name="state" widget="statusbar"
                                               statusbar_visible="pending,received,approved,rejected"/>
                                    </header>
                                    <sheet>
                                        <div class="risk-document-preview-layout">
                                            <div class="risk-document-preview">
                                                <field name="file" filename="filename" widget="pdf_viewer" nolabel="1"/>
                                                <div invisible="file" class="alert alert-info mb-0" role="status">
                                                    Este documento aun no tiene archivo cargado.
                                                </div>
                                            </div>
                                            <div class="risk-document-details">
                                                <group>
                                                    <field name="name"/>
                                                    <field name="document_type"/>
                                                    <field name="party"/>
                                                    <field name="source"/>
                                                    <field name="instructions" placeholder="Instrucciones para el tercero"/>
                                                    <field name="required"/>
                                                    <field name="requires_color"/>
                                                    <field name="requires_both_sides"/>
                                                    <field name="validity_required"/>
                                                    <field name="issue_date_required"/>
                                                    <field name="reject_expired"/>
                                                    <field name="max_age_days"/>
                                                    <field name="max_file_size_mb"/>
                                                    <field name="allowed_file_extensions"/>
                                                    <field name="issue_date"/>
                                                    <field name="expiration_date"/>
                                                    <field name="expiration_state" readonly="1"/>
                                                    <field name="filename"/>
                                                </group>
                                                <group string="Observaciones">
                                                    <field name="rejection_reason"/>
                                                    <field name="observations" nolabel="1"/>
                                                </group>
                                                <group string="Historial">
                                                    <field name="uploaded_by_id"/>
                                                    <field name="uploaded_at"/>
                                                    <field name="approved_by_id"/>
                                                    <field name="approved_at"/>
                                                    <field name="rejected_by_id"/>
                                                    <field name="rejected_at"/>
                                                    <field name="rejection_message_sent_at"/>
                                                    <field name="replacement_count"/>
                                                </group>
                                            </div>
                                        </div>
                                    </sheet>
                                </form>
                            </field>
                        </page>

                        <page string="Validacion Externa" name="external_validation_page">
                            <field name="external_validation_ids" context="{'default_submission_id': id}">
                                <list editable="bottom"
                                      decoration-success="status == 'approved'"
                                      decoration-danger="status == 'rejected'"
                                      decoration-info="status in ('sent', 'manual_review')"
                                      decoration-warning="status in ('pending', 'error')"
                                      decoration-muted="status == 'skipped'">
                                    <field name="status" widget="badge"
                                           decoration-success="status == 'approved'"
                                           decoration-danger="status == 'rejected'"
                                           decoration-info="status in ('sent', 'manual_review')"
                                           decoration-warning="status in ('pending', 'error')"
                                           decoration-muted="status == 'skipped'"/>
                                    <field name="provider"/>
                                    <field name="profile"/>
                                    <field name="external_reference"/>
                                    <field name="risk_score"/>
                                    <field name="requested_at"/>
                                    <field name="completed_at"/>
                                    <field name="summary"/>
                                    <button name="action_send_to_validiti" type="object" string="Enviar"
                                            invisible="provider != 'validiti' or status not in ('pending', 'error')"/>
                                    <button name="action_open_result_wizard" type="object" string="Resultado"
                                            invisible="status in ('approved', 'rejected', 'skipped')"/>
                                    <button name="action_skip" type="object" string="Omitir"
                                            invisible="status in ('approved', 'rejected', 'skipped')"/>
                                </list>
                            </field>
                        </page>

                        <!-- Pestaña 4: Trazabilidad -->
                        <page string="Trazabilidad" name="traceability_page">
                            <group string="Revision de Riesgo">
                                <field name="risk_reviewer_id"/>
                                <field name="risk_reviewed_at"/>
                            </group>
                            <group string="Aprobacion Manual">
                                <group>
                                    <field name="approval_user_id"/>
                                    <field name="approval_date"/>
                                </group>
                                <group>
                                    <field name="approval_note"/>
                                </group>
                            </group>
                            <group string="Rechazo Manual">
                                <group>
                                    <field name="rejection_user_id"/>
                                    <field name="rejection_date"/>
                                </group>
                                <group>
                                    <field name="rejection_reason"/>
                                </group>
                            </group>
                            <group string="Correcciones">
                                <group>
                                    <field name="correction_requested_by_id"/>
                                    <field name="correction_requested_at"/>
                                    <field name="correction_submitted_at"/>
                                    <field name="correction_count"/>
                                </group>
                                <group>
                                    <field name="correction_reason"/>
                                    <field name="correction_section_vehicle"/>
                                    <field name="correction_section_owner"/>
                                    <field name="correction_section_driver"/>
                                    <field name="correction_section_satellite"/>
                                    <field name="correction_section_signatures"/>
                                    <field name="correction_section_terms"/>
                                    <field name="correction_section_other"/>
                                </group>
                            </group>
                            <group string="Trazabilidad de Firma Propietario">
                                <field name="owner_signature_ip"/>
                                <field name="owner_signature_user_agent"/>
                                <field name="owner_signature_code_sent_at"/>
                                <field name="owner_signature_code_expires_at"/>
                                <field name="owner_signature_verified_ip"/>
                                <field name="owner_signature_code_attempts"/>
                            </group>
                            <group string="Trazabilidad de Firma Conductor">
                                <field name="driver_signature_ip"/>
                                <field name="driver_signature_user_agent"/>
                                <field name="driver_signature_code_sent_at"/>
                                <field name="driver_signature_code_expires_at"/>
                                <field name="driver_signature_verified_ip"/>
                                <field name="driver_signature_code_attempts"/>
                            </group>
                        </page>

                        <!-- Pestaña 5: Observaciones -->
                        <page string="Observaciones" name="notes_page">
                            <group>
                                <field name="message" nolabel="1" placeholder="Escriba observaciones o notas adicionales"/>
                            </group>
                        </page>

                        <page string="Guia del flujo" name="flow_guide_page">
                            <div class="alert alert-info" role="status">
                                Usa esta guia para distinguir entre correccion de formulario, rechazo definitivo y rechazo individual de documentos.
                            </div>
                            <group string="Flujo principal">
                                <group>
                                    <separator string="1. Enviado"/>
                                    <p>Revisa que la solicitud tenga datos base suficientes. Accion sugerida: Iniciar revision.</p>
                                    <separator string="2. En revision de riesgo"/>
                                    <p>Valida formulario, firmas y consistencia. Puedes enviar a validacion externa, continuar manualmente, solicitar correccion o rechazar.</p>
                                    <separator string="3. Validacion externa pendiente"/>
                                    <p>Gestiona el proveedor externo y registra el resultado. Si no aplica, continua a aprobacion manual.</p>
                                    <separator string="4. Pendiente aprobacion manual"/>
                                    <p>Punto de decision: aprobar, solicitar documentos, devolver para correccion o rechazar definitivamente.</p>
                                    <separator string="5. Documentos solicitados"/>
                                    <p>El tercero carga soportes desde el portal. Aqui tambien puedes agregar documentos adicionales puntuales.</p>
                                </group>
                                <group>
                                    <separator string="6. Documentos en revision"/>
                                    <p>Aprueba documentos obligatorios. Si un archivo esta mal, rechaza solo el documento, no toda la solicitud.</p>
                                    <separator string="7. Requiere correccion"/>
                                    <p>Usalo cuando el formulario esta mal diligenciado y el tercero puede corregirlo. El portal habilita la misma solicitud.</p>
                                    <separator string="8. Correccion enviada"/>
                                    <p>El tercero ya corrigio. Inicia revision para validar cambios y continuar el flujo.</p>
                                    <separator string="9. Aprobado"/>
                                    <p>Proceso finalizado favorablemente.</p>
                                    <separator string="10. Rechazado"/>
                                    <p>Proceso finalizado definitivamente. Usalo para casos no subsanables como estudio de seguridad no aprobado o politica interna.</p>
                                </group>
                            </group>
                            <group string="Reglas practicas">
                                <group>
                                    <separator string="Rechazo definitivo"/>
                                    <p>Usalo cuando la solicitud no puede continuar. El usuario recibe el motivo, pero no puede editar la solicitud.</p>
                                    <separator string="Devolver para correccion"/>
                                    <p>Usalo cuando hay datos del formulario mal diligenciados. El usuario corrige y reenvia la misma solicitud.</p>
                                </group>
                                <group>
                                    <separator string="Rechazo de documento"/>
                                    <p>Usalo solamente para archivos cargados incorrectos, vencidos o ilegibles. No cambia toda la solicitud a correccion.</p>
                                    <separator string="Documentos adicionales"/>
                                    <p>Usalo para pedir un soporte puntual sin modificar el catalogo global de documentos requeridos.</p>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
</odoo>
