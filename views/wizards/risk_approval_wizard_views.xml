<odoo>
    <record id="view_risk_approval_wizard_form" model="ir.ui.view">
        <field name="name">risk.approval.wizard.form</field>
        <field name="model">risk.approval.wizard</field>
        <field name="arch" type="xml">
            <form string="Decision manual">
                <sheet class="risk-decision-wizard">
                    <div class="risk-decision-header">
                        <div>
                            <div class="risk-decision-eyebrow">Solicitud</div>
                            <field name="submission_id" nolabel="1" readonly="1"/>
                        </div>
                        <div>
                            <div class="risk-decision-eyebrow">Decision</div>
                            <field name="decision" nolabel="1" readonly="1"/>
                        </div>
                    </div>

                    <div class="alert alert-warning mb-3" role="status" invisible="decision != 'correction'">
                        Esta opcion devuelve la solicitud al tercero para que corrija el formulario. No es un rechazo definitivo.
                    </div>

                    <group invisible="decision != 'approve'">
                        <field name="approval_note"
                               placeholder="Comentario opcional para dejar trazabilidad de la aprobacion."/>
                    </group>

                    <div class="risk-correction-layout" invisible="decision != 'correction'">
                        <div class="risk-correction-main">
                            <group string="Motivo y mensaje">
                                <field name="message_template_category" invisible="1"/>
                                <field name="message_template_id"
                                       required="decision == 'correction'"
                                       options="{'no_create': True, 'no_open': True}"/>
                                <field name="rejection_reason_code" invisible="1"/>
                                <field name="rejection_reason" required="decision != 'approve'"
                                       placeholder="Explica de forma clara que debe corregir el usuario."/>
                            </group>
                        </div>
                        <div class="risk-correction-sections">
                            <div class="o_horizontal_separator">Secciones a corregir</div>
                            <div class="risk-correction-section-grid">
                                <div class="risk-correction-section-item">
                                    <field name="correction_section_vehicle" nolabel="1"/>
                                    <label for="correction_section_vehicle"/>
                                </div>
                                <div class="risk-correction-section-item">
                                    <field name="correction_section_owner" nolabel="1"/>
                                    <label for="correction_section_owner"/>
                                </div>
                                <div class="risk-correction-section-item">
                                    <field name="correction_section_driver" nolabel="1"/>
                                    <label for="correction_section_driver"/>
                                </div>
                                <div class="risk-correction-section-item">
                                    <field name="correction_section_satellite" nolabel="1"/>
                                    <label for="correction_section_satellite"/>
                                </div>
                                <div class="risk-correction-section-item">
                                    <field name="correction_section_signatures" nolabel="1"/>
                                    <label for="correction_section_signatures"/>
                                </div>
                                <div class="risk-correction-section-item">
                                    <field name="correction_section_terms" nolabel="1"/>
                                    <label for="correction_section_terms"/>
                                </div>
                                <div class="risk-correction-section-item">
                                    <field name="correction_section_other" nolabel="1"/>
                                    <label for="correction_section_other"/>
                                </div>
                            </div>
                        </div>
                    </div>

                    <group invisible="decision != 'reject'">
                        <field name="message_template_category" invisible="1"/>
                        <field name="message_template_id"
                               required="decision == 'reject'"
                               options="{'no_create': True, 'no_open': True}"/>
                        <field name="rejection_reason_code" invisible="1"/>
                        <field name="rejection_reason" required="decision != 'approve'"
                               readonly="1"
                               placeholder="Este mensaje se enviara al usuario. Debe explicar el motivo del rechazo definitivo."/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm" type="object" string="Confirmar" class="btn-primary"/>
                    <button string="Cancelar" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
