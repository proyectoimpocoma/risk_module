<odoo>
    <record id="view_risk_sharepoint_drive_selector_form" model="ir.ui.view">
        <field name="name">risk.sharepoint.drive.selector.form</field>
        <field name="model">risk.sharepoint.drive.selector</field>
        <field name="arch" type="xml">
            <form string="Seleccionar biblioteca y carpeta">
                <sheet class="risk-sp-explorer">

                    <!-- Paso 1: elegir biblioteca -->
                    <div invisible="stage != 'drive'">
                        <div class="risk-sp-wizard-head">
                            <div>
                                <span class="risk-sp-step-pill">Paso 1 de 2</span>
                                <h4>Biblioteca de documentos</h4>
                                <p class="text-muted">
                                    Selecciona el drive de SharePoint donde se guardarán los documentos.
                                </p>
                            </div>
                        </div>
                        <group>
                            <field name="drive_id" widget="radio" nolabel="1"/>
                        </group>
                    </div>

                    <!-- Paso 2: navegar carpetas -->
                    <div invisible="stage != 'folder'">
                        <div class="risk-sp-wizard-head">
                            <div>
                                <span class="risk-sp-step-pill">Paso 2 de 2</span>
                                <h4>Carpeta raíz</h4>
                                <p class="text-muted">
                                    Navega hasta la carpeta donde se crearán las subcarpetas por solicitud.
                                </p>
                            </div>
                            <div class="risk-sp-current-path">
                                <span>Ubicación actual</span>
                                <field name="path_display" readonly="1" nolabel="1"/>
                            </div>
                        </div>
                        <field name="stage" invisible="1"/>
                        <field name="selected_drive_id" invisible="1"/>
                        <field name="current_path" invisible="1"/>
                        <field name="current_item_id" invisible="1"/>
                        <field name="test_upload_item_id" invisible="1"/>
                        <field name="folder_choice" invisible="1"/>
                        <group>
                            <group string="Contenido">
                                <div class="risk-sp-counts">
                                    <div>
                                        <span>Carpetas</span>
                                        <field name="folder_count" readonly="1" nolabel="1"/>
                                    </div>
                                    <div>
                                        <span>Archivos</span>
                                        <field name="file_count" readonly="1" nolabel="1"/>
                                    </div>
                                </div>
                                <field name="explorer_message" readonly="1" nolabel="1"
                                       invisible="not explorer_message"/>
                            </group>
                        </group>
                        <field name="line_ids" nolabel="1">
                            <list create="false" edit="false" delete="false">
                                <field name="item_type" string="Tipo" readonly="1"/>
                                <field name="name" string="Nombre" readonly="1"/>
                                <field name="size" string="Tamaño" readonly="1" optional="hide"/>
                                <button string="Abrir" type="object" name="action_open_folder"
                                        class="btn-link" icon="fa-folder-open"
                                        invisible="not is_folder"/>
                                <button string="Ver archivo" type="object" name="action_open_file"
                                        class="btn-link" icon="fa-external-link"
                                        invisible="not is_file or not web_url"/>
                                <field name="is_folder" column_invisible="1"/>
                                <field name="is_file" column_invisible="1"/>
                                <field name="web_url" column_invisible="1"/>
                            </list>
                        </field>
                        <div class="mt-2 risk-sp-action-row">
                            <button string="Subir nivel" type="object" name="action_go_up"
                                    class="btn-secondary btn-sm"
                                    icon="fa-level-up"
                                    invisible="not current_item_id"/>
                            <button string="Refrescar" type="object" name="action_refresh"
                                    class="btn-secondary btn-sm"
                                    icon="fa-refresh"/>
                            <button string="Cambiar biblioteca" type="object" name="action_change_drive"
                                    class="btn-secondary btn-sm"
                                    icon="fa-exchange"/>
                        </div>
                        <group string="Crear carpeta">
                            <field name="new_folder_name" placeholder="Nombre de la nueva carpeta"/>
                            <button string="Crear carpeta" type="object" name="action_create_folder"
                                    class="btn-secondary" icon="fa-plus"
                                    invisible="not new_folder_name"/>
                        </group>
                        <group string="Prueba de escritura">
                            <field name="test_file" filename="test_filename"/>
                            <field name="test_filename"/>
                            <field name="test_upload_message" readonly="1" nolabel="1"
                                   invisible="not test_upload_message"/>
                            <field name="test_upload_web_url" widget="url" readonly="1"
                                   invisible="not test_upload_web_url"/>
                            <div>
                                <button string="Subir prueba" type="object" name="action_upload_test_file"
                                        class="btn-secondary" icon="fa-upload"
                                        invisible="not test_file"/>
                                <button string="Abrir prueba" type="object" name="action_open_test_file"
                                        class="btn-secondary ms-2" icon="fa-external-link"
                                        invisible="not test_upload_web_url"/>
                                <button string="Eliminar prueba" type="object" name="action_delete_test_file"
                                        class="btn-secondary ms-2" icon="fa-trash"
                                        invisible="not test_upload_item_id"/>
                            </div>
                        </group>
                    </div>

                </sheet>
                <footer>
                    <!-- Etapa drive: avanzar al paso 2 -->
                    <button string="Siguiente" type="object" name="action_next_stage"
                            class="btn-primary" icon="fa-arrow-right"
                            invisible="stage != 'drive'"/>
                    <!-- Etapa folder: confirmar selección -->
                    <button string="Seleccionar esta carpeta" type="object" name="action_confirm"
                            class="btn-primary" icon="fa-check"
                            invisible="stage != 'folder'"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
