<odoo>
    <record id="view_risk_sharepoint_drive_selector_form" model="ir.ui.view">
        <field name="name">risk.sharepoint.drive.selector.form</field>
        <field name="model">risk.sharepoint.drive.selector</field>
        <field name="arch" type="xml">
            <form string="Seleccionar biblioteca de SharePoint">
                <sheet>
                    <div class="o_form_view">
                        <p class="text-muted">
                            Selecciona la biblioteca (drive) de SharePoint donde se guardarán los documentos.
                            Esta lista se obtiene directamente desde el sitio configurado.
                        </p>
                        <group>
                            <field name="drive_id" widget="radio"/>
                        </group>
                    </div>
                </sheet>
                <footer>
                    <button string="Seleccionar" type="object" name="action_confirm" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
