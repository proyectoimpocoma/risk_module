<odoo>
    <record id="view_risk_external_validation_result_wizard_form" model="ir.ui.view">
        <field name="name">risk.external.validation.result.wizard.form</field>
        <field name="model">risk.external.validation.result.wizard</field>
        <field name="arch" type="xml">
            <form string="Registrar resultado Validiti">
                <group>
                    <field name="validation_id"/>
                    <field name="decision"/>
                    <field name="external_reference"/>
                    <field name="risk_score"/>
                    <field name="summary" placeholder="Resume el resultado, alertas encontradas o motivo de la decision."/>
                    <field name="response_payload" placeholder="Pega aqui la respuesta, evidencia o referencia del resultado externo."/>
                </group>
                <footer>
                    <button name="action_confirm" type="object" string="Confirmar" class="btn-primary"/>
                    <button string="Cancelar" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
